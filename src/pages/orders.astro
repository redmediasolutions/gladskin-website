---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="My Orders | Gladskin">
  <Header />
  <main style="padding-top:3.25rem; min-height:100vh; background:var(--surface);">
    <div style="max-width:56rem; margin:0 auto; padding:1.5rem clamp(1.25rem,4vw,3rem) 3rem;">

      <h1 class="font-headline" style="font-size:clamp(1.75rem,3vw,2.5rem); color:var(--on-surface); margin:0 0 2rem;">My Orders</h1>

      <!-- Empty -->
      <div id="orders-empty" style="display:none; text-align:center; padding:5rem 0;">
        <span class="material-symbols-outlined" style="font-size:4rem; color:var(--outline-variant); display:block; margin-bottom:1rem;">receipt_long</span>
        <p style="font-family:'Manrope',sans-serif; color:var(--on-surface-variant); margin:0 0 1.5rem;">You haven't placed any orders yet.</p>
        <a href="/collection" style="display:inline-block; padding:1rem 2.5rem; background:var(--primary); color:#fff; border-radius:9999px; font-family:'Manrope',sans-serif; font-weight:700; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; text-decoration:none;">Start Shopping</a>
      </div>

      <!-- Orders list -->
      <div id="orders-list" style="display:flex; flex-direction:column; gap:1rem;"></div>
    </div>

    <!-- Order detail modal -->
    <div id="modal-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:200; align-items:center; justify-content:center; padding:1rem;">
      <div id="modal-box" style="background:var(--surface); border-radius:1.25rem; width:100%; max-width:36rem; max-height:90vh; overflow-y:auto; padding:1.5rem; position:relative;">
        <button id="modal-close" style="position:absolute; top:1rem; right:1rem; background:none; border:none; cursor:pointer; color:var(--on-surface-variant);">
          <span class="material-symbols-outlined">close</span>
        </button>
        <div id="modal-content"></div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const ORDERS_KEY = 'gladskin_orders';

  const STATUS_CONFIG: Record<string, { color: string; bg: string; icon: string; label: string }> = {
    pending:    { color:'#c9960c', bg:'rgba(201,150,12,0.1)',  icon:'schedule',       label:'Pending' },
    processing: { color:'#1565c0', bg:'rgba(21,101,192,0.1)', icon:'local_shipping', label:'Processing' },
    completed:  { color:'#2e7d32', bg:'rgba(46,125,50,0.1)',  icon:'check_circle',   label:'Delivered' },
    cancelled:  { color:'#c62828', bg:'rgba(198,40,40,0.1)',  icon:'cancel',         label:'Cancelled' },
  };

  function getOrders() { try { return JSON.parse(localStorage.getItem(ORDERS_KEY)||'[]'); } catch{return[];} }

  function formatDate(iso: string) {
    return new Date(iso).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' });
  }

  function openModal(order: any) {
    const s = STATUS_CONFIG[order.status] || STATUS_CONFIG.pending;
    const overlay = document.getElementById('modal-overlay')!;
    overlay.style.display = 'flex';
    document.getElementById('modal-content')!.innerHTML = `
      <div style="margin-bottom:1.25rem;">
        <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:0.5rem;">
          <div>
            <div style="font-family:'Manrope',sans-serif; font-size:0.7rem; color:var(--on-surface-variant); letter-spacing:0.1em; text-transform:uppercase;">Order ID</div>
            <div style="font-family:'Noto Serif',serif; font-size:1.1rem; color:var(--primary);">${order.id}</div>
          </div>
          <span style="background:${s.bg}; color:${s.color}; font-family:'Manrope',sans-serif; font-size:0.72rem; font-weight:700; padding:0.3rem 0.75rem; border-radius:9999px; display:flex; align-items:center; gap:0.3rem;">
            <span class="material-symbols-outlined" style="font-size:0.9rem; font-variation-settings:'FILL' 1">${s.icon}</span>${s.label}
          </span>
        </div>
        <div style="font-family:'Manrope',sans-serif; font-size:0.8rem; color:var(--on-surface-variant); margin-top:0.3rem;">${formatDate(order.createdAt)}</div>
      </div>

      <h3 style="font-family:'Manrope',sans-serif; font-size:0.75rem; font-weight:800; letter-spacing:0.15em; text-transform:uppercase; color:var(--on-surface); margin:0 0 0.75rem; border-top:1px solid var(--outline-variant); padding-top:1rem;">Items Ordered</h3>
      <div style="display:flex; flex-direction:column; gap:0.75rem; margin-bottom:1rem;">
        ${order.items.map((item: any) => `
          <div style="display:grid; grid-template-columns:3.5rem 1fr; gap:0.75rem; align-items:center;">
            <div style="border-radius:0.4rem; overflow:hidden; aspect-ratio:3/4; background:var(--surface-container);">
              <img src="${item.image}" style="width:100%; height:100%; object-fit:cover;" />
            </div>
            <div>
              <div style="font-family:'Manrope',sans-serif; font-size:0.85rem; font-weight:600; color:var(--on-surface);">${item.name}</div>
              <div style="font-family:'Manrope',sans-serif; font-size:0.75rem; color:var(--on-surface-variant);">Qty: ${item.quantity||1} &nbsp;·&nbsp; ₹${item.price.toFixed(2)}</div>
            </div>
          </div>
        `).join('')}
      </div>

      <div style="background:var(--surface-container-low); border-radius:0.75rem; padding:1rem; margin-bottom:1rem;">
        <h3 style="font-family:'Manrope',sans-serif; font-size:0.75rem; font-weight:800; letter-spacing:0.15em; text-transform:uppercase; color:var(--on-surface); margin:0 0 0.75rem;">Bill Summary</h3>
        <div style="display:flex; flex-direction:column; gap:0.5rem;">
          <div style="display:flex; justify-content:space-between; font-family:'Manrope',sans-serif; font-size:0.85rem; color:var(--on-surface-variant);">
            <span>Subtotal</span><span>₹${order.subtotal.toFixed(2)}</span>
          </div>
          <div style="display:flex; justify-content:space-between; font-family:'Manrope',sans-serif; font-size:0.85rem; color:var(--on-surface-variant);">
            <span>Shipping</span><span style="color:${order.shipping===0?'var(--tertiary)':'inherit'}">${order.shipping===0?'FREE':'₹'+order.shipping}</span>
          </div>
          <div style="display:flex; justify-content:space-between; font-family:'Noto Serif',serif; font-size:1rem; color:var(--on-surface); border-top:1px solid var(--outline-variant); padding-top:0.5rem; margin-top:0.25rem;">
            <span>Total</span><span>₹${order.total.toFixed(2)}</span>
          </div>
          <div style="font-family:'Manrope',sans-serif; font-size:0.75rem; color:var(--on-surface-variant); display:flex; align-items:center; gap:0.3rem; margin-top:0.25rem;">
            <span class="material-symbols-outlined" style="font-size:0.9rem;">payments</span> Cash on Delivery
          </div>
        </div>
      </div>

      <div style="background:var(--surface-container-low); border-radius:0.75rem; padding:1rem; margin-bottom:1rem;">
        <h3 style="font-family:'Manrope',sans-serif; font-size:0.75rem; font-weight:800; letter-spacing:0.15em; text-transform:uppercase; color:var(--on-surface); margin:0 0 0.5rem;">Delivery Address</h3>
        <div style="font-family:'Manrope',sans-serif; font-size:0.85rem; color:var(--on-surface); font-weight:600;">${order.address.name}</div>
        <div style="font-family:'Manrope',sans-serif; font-size:0.82rem; color:var(--on-surface-variant); line-height:1.5;">
          ${order.address.addressLine}<br/>
          ${order.address.city}, ${order.address.state} – ${order.address.pincode}<br/>
          📞 ${order.address.phone}
        </div>
      </div>

      ${['pending','processing'].includes(order.status) ? `
        <div style="background:rgba(198,40,40,0.05); border:1px solid rgba(198,40,40,0.2); border-radius:0.75rem; padding:1rem;">
          <div style="display:flex; align-items:flex-start; gap:0.75rem; margin-bottom:1rem;">
            <span class="material-symbols-outlined" style="color:#c62828; font-size:1.25rem; flex-shrink:0;">info</span>
            <p style="font-family:'Manrope',sans-serif; font-size:0.8rem; color:var(--on-surface-variant); margin:0; line-height:1.5;">
              Cancellations are only possible before the order is dispatched. Once cancelled, the order cannot be restored.
            </p>
          </div>
          <button
            onclick="window.__cancelOrder('${order.id}')"
            style="width:100%; padding:0.875rem; background:none; border:1.5px solid #c62828; border-radius:9999px; font-family:'Manrope',sans-serif; font-weight:700; font-size:0.75rem; letter-spacing:0.15em; text-transform:uppercase; color:#c62828; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:0.5rem; transition:background 0.2s;"
            onmouseover="this.style.background='rgba(198,40,40,0.06)'"
            onmouseout="this.style.background='none'">
            <span class="material-symbols-outlined" style="font-size:1rem;">cancel</span>
            Cancel Order
          </button>
        </div>
      ` : ''}
    `;
  }

  document.getElementById('modal-close')!.addEventListener('click', () => {
    document.getElementById('modal-overlay')!.style.display = 'none';
  });
  document.getElementById('modal-overlay')!.addEventListener('click', (e) => {
    if (e.target === document.getElementById('modal-overlay')) {
      (document.getElementById('modal-overlay') as HTMLElement).style.display = 'none';
    }
  });

  function renderOrders() {
    const orders = getOrders();
    const emptyEl = document.getElementById('orders-empty')!;
    const listEl  = document.getElementById('orders-list')!;

    if (orders.length === 0) { emptyEl.style.display='block'; return; }
    emptyEl.style.display = 'none';

    listEl.innerHTML = orders.map((order: any) => {
      const s = STATUS_CONFIG[order.status] || STATUS_CONFIG.pending;
      const thumbs = order.items.slice(0,4).map((i:any) =>
        `<img src="${i.image}" style="width:2.75rem; height:2.75rem; border-radius:0.4rem; object-fit:cover; border:2px solid var(--surface);" />`
      ).join('');
      const extra = order.items.length > 4 ? `<div style="width:2.75rem;height:2.75rem;border-radius:0.4rem;background:var(--surface-container);display:flex;align-items:center;justify-content:center;font-family:'Manrope',sans-serif;font-size:0.7rem;font-weight:700;color:var(--on-surface-variant);">+${order.items.length-4}</div>` : '';

      return `
        <div id="order-${order.id}" class="order-card" onclick="window.__openOrder('${order.id}')"
          style="background:var(--surface-container-lowest); border:1px solid var(--outline-variant); border-radius:1rem; padding:1.25rem; cursor:pointer; transition:box-shadow 0.2s;"
          onmouseover="this.style.boxShadow='0 4px 20px rgba(0,0,0,0.08)'" onmouseout="this.style.boxShadow='none'">
          <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:0.5rem; margin-bottom:1rem;">
            <div>
              <div style="font-family:'Manrope',sans-serif; font-size:0.7rem; color:var(--on-surface-variant); letter-spacing:0.08em; text-transform:uppercase;">Order #${order.id}</div>
              <div style="font-family:'Manrope',sans-serif; font-size:0.8rem; color:var(--on-surface-variant);">${formatDate(order.createdAt)}</div>
            </div>
            <span style="background:${s.bg}; color:${s.color}; font-family:'Manrope',sans-serif; font-size:0.7rem; font-weight:700; padding:0.3rem 0.75rem; border-radius:9999px; display:flex; align-items:center; gap:0.3rem;">
              <span class="material-symbols-outlined" style="font-size:0.85rem; font-variation-settings:'FILL' 1">${s.icon}</span>${s.label}
            </span>
          </div>
          <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:0.75rem;">
            <div style="display:flex; gap:0.4rem;">${thumbs}${extra}</div>
            <div style="text-align:right;">
              <div style="font-family:'Manrope',sans-serif; font-size:0.75rem; color:var(--on-surface-variant);">${order.items.length} item${order.items.length>1?'s':''} &nbsp;·&nbsp; COD</div>
              <div style="font-family:'Noto Serif',serif; font-size:1rem; color:var(--on-surface); font-weight:400;">₹${order.total.toFixed(2)}</div>
            </div>
          </div>
        </div>
      `;
    }).join('');

    // Highlight if coming from success page
    const params = new URLSearchParams(window.location.search);
    const highlight = params.get('highlight');
    if (highlight) {
      setTimeout(() => {
        const el = document.getElementById(`order-${highlight}`);
        if (el) {
          el.style.borderColor = 'var(--primary)';
          el.scrollIntoView({ behavior:'smooth', block:'center' });
        }
      }, 300);
    }
  }

  (window as any).__openOrder = (id: string) => {
    const order = getOrders().find((o:any) => o.id === id);
    if (order) openModal(order);
  };

  (window as any).__cancelOrder = (id: string) => {
    const confirmed = window.confirm('Are you sure you want to cancel this order? This cannot be undone.');
    if (!confirmed) return;

    const orders = getOrders();
    const order  = orders.find((o: any) => o.id === id);
    if (!order) return;

    order.status = 'cancelled';
    localStorage.setItem(ORDERS_KEY, JSON.stringify(orders));

    // Close modal and re-render list
    document.getElementById('modal-overlay')!.style.display = 'none';
    renderOrders();

    // Show toast
    let t = document.getElementById('cancel-toast');
    if (!t) {
      t = document.createElement('div');
      t.id = 'cancel-toast';
      t.style.cssText = 'position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(4rem);background:#c62828;color:#fff;padding:0.75rem 1.5rem;border-radius:9999px;font-family:Manrope,sans-serif;font-size:0.8rem;font-weight:600;opacity:0;transition:all 0.3s;z-index:300;white-space:nowrap;';
      document.body.appendChild(t);
    }
    t.textContent = 'Order cancelled successfully';
    t.style.opacity = '1';
    t.style.transform = 'translateX(-50%) translateY(0)';
    setTimeout(() => { t!.style.opacity='0'; t!.style.transform='translateX(-50%) translateY(4rem)'; }, 3000);
  };

  renderOrders();
</script>
