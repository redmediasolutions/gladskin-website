---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getProductBySlug } from '../../data/products.ts';

const { slug } = Astro.params;
const product = await getProductBySlug(slug!);

if (!product) {
  return Astro.redirect('/collection');
}

const discountPercent = product.originalPrice && product.originalPrice > product.price
  ? Math.round(((product.originalPrice - product.price) / product.originalPrice) * 100)
  : null;
---

<BaseLayout title={`${product.name} | Gladskin`} description={`Discover ${product.name} – ${product.category}`}>
  <Header />
  <main class="pd-main">

    <!-- Breadcrumb -->
    <div class="pd-breadcrumb">
      <a href="/collection" class="pd-back">
        <span class="material-symbols-outlined">arrow_back</span>
        Collection
      </a>
      <span class="pd-breadcrumb-sep">/</span>
      <span class="pd-breadcrumb-current">{product.name}</span>
    </div>

    <div class="pd-grid">

      <!-- ── Image column ── -->
      <div class="pd-image-col">
        <div class="pd-image-wrap">
          <img src={product.image} alt={product.imageAlt || product.name} class="pd-image" />
          {discountPercent !== null && (
            <span class="pd-discount-badge">{discountPercent}% OFF</span>
          )}
        </div>
      </div>

      <!-- ── Info column ── -->
      <div class="pd-info-col">

        <!-- Category -->
        <span class="pd-category">{product.category}</span>

        <!-- Name -->
        <h1 class="pd-name font-headline">{product.name}</h1>

        <!-- Price -->
        <div class="pd-price-row">
          <span class="pd-price">₹{product.price.toFixed(0)}</span>
          {product.originalPrice && product.originalPrice > product.price && (
            <span class="pd-price-original">₹{product.originalPrice.toFixed(0)}</span>
          )}
        </div>

        {discountPercent !== null && product.originalPrice && (
          <div class="pd-savings-row">
            <span class="material-symbols-outlined" style="font-size:1rem; font-variation-settings:'FILL' 1;">savings</span>
            You save ₹{(product.originalPrice - product.price).toFixed(0)}
          </div>
        )}

        <!-- Divider -->
        <div class="pd-divider"></div>

        <!-- Description -->
        <p class="pd-desc">
          {product.description || 'A rare botanical formulation crafted from the finest extracts. Each application delivers concentrated cellular intelligence to transform your skin\'s natural repair architecture.'}
        </p>

        <!-- Out of stock -->
        {product.inStock === false && (
          <div class="pd-out-of-stock">
            <span class="material-symbols-outlined">cancel</span>
            Out of Stock
          </div>
        )}

        <!-- Quantity + CTA -->
        <div class="pd-actions">
          <div class="pd-qty-row">
            <span class="pd-qty-label">Qty</span>
            <div class="pd-qty-ctrl">
              <button id="qty-minus" class="pd-qty-btn">−</button>
              <span id="qty-display" class="pd-qty-val">1</span>
              <button id="qty-plus" class="pd-qty-btn">+</button>
            </div>
          </div>

          <button id="add-to-cart" class="pd-btn-primary" data-product-id={product.id}>
            <span class="material-symbols-outlined">shopping_bag</span>
            Add to Bag
          </button>

          <button
            id="add-to-wishlist"
            class="pd-btn-secondary"
            data-product-id={product.id}
            data-product={JSON.stringify({ id: product.id, name: product.name, price: product.price, originalPrice: product.originalPrice, image: product.image, imageAlt: product.imageAlt, slug: product.slug, category: product.category })}
            style="display:none"
          >
            <span class="material-symbols-outlined" id="wishlist-icon">favorite_border</span>
            <span id="wishlist-label">Save to Wishlist</span>
          </button>
        </div>

        <!-- Trust pills -->
        <div class="pd-trust">
          {[
            { icon: 'eco',            label: 'Botanical' },
            { icon: 'science',        label: 'Lab Tested' },
            { icon: 'local_shipping', label: 'Free Delivery' },
            { icon: 'recycling',      label: 'Eco Pack' },
          ].map(f => (
            <div class="pd-trust-pill">
              <span class="material-symbols-outlined">{f.icon}</span>
              {f.label}
            </div>
          ))}
        </div>

        <!-- Tabs -->
        {(product.howItWorks || product.composition || product.sideEffects) && (
          <div class="pd-tabs-wrap">
            <div class="pd-tabs">
              {product.howItWorks  && <button class="tab-btn active" data-tab="how">How It Works</button>}
              {product.composition && <button class="tab-btn" data-tab="comp">Ingredients</button>}
              {product.sideEffects && <button class="tab-btn" data-tab="side">Safety</button>}
            </div>
            {product.howItWorks  && <div class="tab-panel pd-tab-body" data-panel="how"  style="display:block">{product.howItWorks}</div>}
            {product.composition && <div class="tab-panel pd-tab-body" data-panel="comp" style="display:none">{product.composition}</div>}
            {product.sideEffects && (
              <div class="tab-panel" data-panel="side" style="display:none">
                <div class="pd-safety">
                  <span class="material-symbols-outlined">info</span>
                  <p class="pd-tab-body" style="margin:0">{product.sideEffects}</p>
                </div>
              </div>
            )}
          </div>
        )}

      </div><!-- /pd-info-col -->
    </div><!-- /pd-grid -->

    <!-- Highlights -->
    {product.highlights && product.highlights.length > 0 && (
      <div class="pd-highlights">
        <p class="pd-section-eyebrow">Why It Works</p>
        <div class="pd-highlights-grid">
          {product.highlights.map(h => (
            <div class="pd-highlight-card">
              <div class="pd-highlight-icon">
                {h.icon && h.icon.startsWith('http')
                  ? <img src={h.icon} alt="" class="pd-highlight-icon-img" />
                  : <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;">
                      {h.icon || 'star'}
                    </span>
                }
              </div>
              {h.title && <div class="pd-highlight-title">{h.title}</div>}
              {h.description && <div class="pd-highlight-body">{h.description}</div>}
            </div>
          ))}
        </div>
      </div>
    )}

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Page shell ── */
  .pd-main {
    padding-top: 3.25rem;
    min-height: 100vh;
    background: var(--surface);
  }

  /* ── Breadcrumb ── */
  .pd-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1.25rem clamp(1.25rem, 4vw, 3rem);
    max-width: 80rem;
    margin: 0 auto;
  }
  .pd-back {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'Manrope', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--on-surface-variant);
    text-decoration: none;
    transition: color 0.2s;
  }
  .pd-back:hover { color: var(--primary); }
  .pd-back .material-symbols-outlined { font-size: 0.95rem; }
  .pd-breadcrumb-sep {
    font-family: 'Manrope', sans-serif;
    font-size: 0.72rem;
    color: var(--outline-variant);
  }
  .pd-breadcrumb-current {
    font-family: 'Manrope', sans-serif;
    font-size: 0.72rem;
    color: var(--on-surface-variant);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 20rem;
  }

  /* ── Two-column grid ── */
  .pd-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 3rem) 3rem;
  }
  @media (min-width: 768px) {
    .pd-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }
  }

  /* ── Image column ── */
  .pd-image-col {
    position: sticky;
    top: 5rem;
  }
  .pd-image-wrap {
    position: relative;
    border-radius: 1.25rem;
    overflow: hidden;
    background: linear-gradient(145deg, #fdf6fb 0%, #f5eef8 100%);
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pd-image {
    width: 88%;
    height: 88%;
    object-fit: contain;
    display: block;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .pd-image-wrap:hover .pd-image { transform: scale(1.04); }
  .pd-discount-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: #1a1a1a;
    color: #fff;
    font-family: 'Manrope', sans-serif;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
    border-radius: 9999px;
  }

  /* ── Info column ── */
  .pd-info-col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-top: 0.5rem;
  }
  @media (max-width: 767px) {
    .pd-info-col { padding-top: 2rem; }
    .pd-image-col { position: static; }
  }

  /* Category */
  .pd-category {
    font-family: 'Manrope', sans-serif;
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--primary);
    display: block;
  }

  /* Name */
  .pd-name {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    color: var(--on-surface);
    margin: 0;
    line-height: 1.15;
    font-weight: 400;
  }

  /* Price */
  .pd-price-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .pd-price {
    font-family: 'Manrope', sans-serif;
    font-size: 1.75rem;
    font-weight: 300;
    color: var(--on-surface);
    letter-spacing: -0.02em;
  }
  .pd-price-original {
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    color: var(--on-surface-variant);
    text-decoration: line-through;
    opacity: 0.5;
  }

  .pd-savings-row {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: #FEF0F4;
    border: 1px solid #F5C2D2;
    border-radius: 9999px;
    padding: 0.35rem 0.875rem;
    font-family: 'Manrope', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: #B34E6F;
    margin-top: -0.5rem;
  }

  .pd-divider {
    height: 1px;
    background: var(--outline-variant);
  }

  /* Description */
  .pd-desc {
    font-family: 'Manrope', sans-serif;
    font-size: 0.92rem;
    color: var(--on-surface-variant);
    line-height: 1.85;
    margin: 0;
  }

  /* Out of stock */
  .pd-out-of-stock {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(198, 40, 40, 0.07);
    color: #c62828;
    border-radius: 9999px;
    padding: 0.4rem 1rem;
    font-family: 'Manrope', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .pd-out-of-stock .material-symbols-outlined { font-size: 0.95rem; }

  /* ── Actions ── */
  .pd-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .pd-qty-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .pd-qty-label {
    font-family: 'Manrope', sans-serif;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--on-surface-variant);
  }
  .pd-qty-ctrl {
    display: flex;
    align-items: center;
    border: 1px solid var(--outline-variant);
    border-radius: 9999px;
    overflow: hidden;
    background: var(--surface-container-lowest);
  }
  .pd-qty-btn {
    width: 2.5rem;
    height: 2.5rem;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.1rem;
    color: var(--on-surface);
    transition: background 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pd-qty-btn:hover { background: rgba(111, 5, 98, 0.06); }
  .pd-qty-val {
    font-family: 'Manrope', sans-serif;
    font-size: 0.88rem;
    font-weight: 700;
    min-width: 2.5rem;
    text-align: center;
    color: var(--on-surface);
  }

  .pd-btn-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: var(--primary);
    color: #fff;
    border: none;
    border-radius: 9999px;
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
    box-shadow: 0 6px 20px rgba(111, 5, 98, 0.22);
  }
  .pd-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(111, 5, 98, 0.32);
  }
  .pd-btn-primary .material-symbols-outlined { font-size: 1.05rem; }

  .pd-btn-secondary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.9rem 2rem;
    background: transparent;
    color: var(--primary);
    border: 1.5px solid rgba(111, 5, 98, 0.25);
    border-radius: 9999px;
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
  }
  .pd-btn-secondary:hover { background: rgba(111, 5, 98, 0.05); border-color: var(--primary); }
  .pd-btn-secondary .material-symbols-outlined { font-size: 1.05rem; }

  /* ── Trust pills ── */
  .pd-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .pd-trust-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'Manrope', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--on-surface-variant);
    background: var(--surface-container-low);
    border: 1px solid var(--outline-variant);
    border-radius: 9999px;
    padding: 0.3rem 0.75rem;
  }
  .pd-trust-pill .material-symbols-outlined { font-size: 0.85rem; color: var(--primary); }

  /* ── Tabs ── */
  .pd-tabs-wrap {
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    overflow: hidden;
  }
  .pd-tabs {
    display: flex;
    border-bottom: 1px solid var(--outline-variant);
    background: var(--surface-container-lowest);
  }
  .tab-btn {
    flex: 1;
    padding: 0.75rem 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Manrope', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--on-surface-variant);
    transition: all 0.18s;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }
  .tab-btn.active,
  .tab-btn:hover { color: var(--primary); }
  .tab-btn.active { border-bottom-color: var(--primary); background: var(--surface); }
  .pd-tab-body {
    font-family: 'Manrope', sans-serif;
    font-size: 0.85rem;
    color: var(--on-surface-variant);
    line-height: 1.8;
    padding: 1.25rem;
  }
  .pd-safety {
    display: flex;
    gap: 0.75rem;
    background: rgba(201, 150, 12, 0.07);
    padding: 1.25rem;
  }
  .pd-safety .material-symbols-outlined { color: #c9960c; flex-shrink: 0; }

  /* ── Highlights ── */
  .pd-highlights {
    max-width: 80rem;
    margin: 0 auto;
    padding: 3rem clamp(1.25rem, 4vw, 3rem) 4rem;
    border-top: 1px solid var(--outline-variant);
  }
  .pd-section-eyebrow {
    font-family: 'Manrope', sans-serif;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--primary);
    margin: 0 0 1.75rem;
  }
  .pd-highlights-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .pd-highlights-grid { grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  }
  /* Card — mirrors app's _highlightCard container */
  .pd-highlight-card {
    background: #F8F4F6;
    border: 1px solid #F1E5EC;
    border-radius: 1.5rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    min-height: 10rem;
    box-shadow: 0 8px 18px rgba(0,0,0,0.03);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .pd-highlight-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 28px rgba(111,5,98,0.1);
  }
  /* Icon box — mirrors 68×68 container with #F1E7ED bg */
  .pd-highlight-icon {
    width: 4rem;
    height: 4rem;
    background: #F1E7ED;
    border-radius: 1.125rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-bottom: 1.5rem;
  }
  .pd-highlight-icon .material-symbols-outlined {
    font-size: 1.5rem;
    color: #8A206E;
  }
  .pd-highlight-icon-img {
    width: 1.5rem;
    height: 1.5rem;
    object-fit: contain;
  }
  /* Title — mirrors Playfair Display, w700 */
  .pd-highlight-title {
    font-family: 'Noto Serif', serif;
    font-size: clamp(0.95rem, 1.4vw, 1.15rem);
    font-weight: 700;
    color: #1D1B1C;
    line-height: 1.25;
    margin-bottom: 0.875rem;
  }
  /* Body — mirrors Manrope, 16px, #5B4A55, line-height 1.8 */
  .pd-highlight-body {
    font-family: 'Manrope', sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    color: #5B4A55;
    line-height: 1.8;
    margin: 0;
  }
</style>

<script>
  import { subscribeToAuth } from '../../lib/auth';
  import { addToCart } from '../../lib/firestore-data';

  const WISHLIST_KEY = 'gladskin_wishlist';
  const productData = JSON.parse(document.getElementById('add-to-wishlist')!.dataset.product!);

  function getWishlist() {
    try { return JSON.parse(localStorage.getItem(WISHLIST_KEY) || '[]'); } catch { return []; }
  }

  let currentUid: string | null = null;
  subscribeToAuth(user => { currentUid = user ? user.uid : null; });

  function showToast(msg: string) {
    let t = document.getElementById('product-toast');
    if (!t) {
      t = document.createElement('div');
      t.id = 'product-toast';
      t.style.cssText = 'position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(4rem);background:var(--on-surface);color:var(--surface);padding:0.75rem 1.5rem;border-radius:9999px;font-family:Manrope,sans-serif;font-size:0.8rem;font-weight:600;opacity:0;transition:all 0.3s;z-index:100;white-space:nowrap;';
      document.body.appendChild(t);
    }
    t.textContent = msg;
    t.style.opacity = '1';
    t.style.transform = 'translateX(-50%) translateY(0)';
    setTimeout(() => { t!.style.opacity='0'; t!.style.transform='translateX(-50%) translateY(4rem)'; }, 2500);
  }

  // Qty controls
  let qty = 1;
  const display = document.getElementById('qty-display')!;
  document.getElementById('qty-minus')?.addEventListener('click', () => { if (qty > 1) { qty--; display.textContent = String(qty); } });
  document.getElementById('qty-plus')?.addEventListener('click', () => { qty++; display.textContent = String(qty); });

  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab!;
      document.querySelectorAll('.tab-btn').forEach(b => {
        (b as HTMLElement).classList.toggle('active', (b as HTMLElement).dataset.tab === tab);
      });
      document.querySelectorAll('.tab-panel').forEach(p => {
        (p as HTMLElement).style.display = (p as HTMLElement).dataset.panel === tab ? 'block' : 'none';
      });
    });
  });

  // Add to cart
  document.getElementById('add-to-cart')?.addEventListener('click', async () => {
    if (!currentUid) {
      window.location.href = `/login?next=${encodeURIComponent(window.location.pathname)}`;
      return;
    }
    try {
      await addToCart(currentUid, productData, qty);
      showToast('Added to bag');
    } catch {
      showToast('Could not add to bag. Try again.');
    }
  });

  // Wishlist toggle
  const wishlistBtn   = document.getElementById('add-to-wishlist')!;
  const wishlistIcon  = document.getElementById('wishlist-icon')!;
  const wishlistLabel = document.getElementById('wishlist-label')!;

  function syncWishlistBtn() {
    const saved = getWishlist().some((i: any) => i.id === productData.id);
    wishlistIcon.textContent  = saved ? 'favorite' : 'favorite_border';
    wishlistLabel.textContent = saved ? 'Saved' : 'Save to Wishlist';
    wishlistIcon.style.color  = saved ? 'var(--secondary)' : '';
    wishlistBtn.style.borderColor = saved ? 'var(--secondary)' : '';
    wishlistBtn.style.color       = saved ? 'var(--secondary)' : '';
    wishlistBtn.classList.toggle('saved', saved);
  }

  syncWishlistBtn();

  wishlistBtn.addEventListener('click', () => {
    const list = getWishlist();
    const idx  = list.findIndex((i: any) => i.id === productData.id);
    if (idx > -1) {
      list.splice(idx, 1);
      localStorage.setItem(WISHLIST_KEY, JSON.stringify(list));
      showToast('Removed from wishlist');
    } else {
      list.push(productData);
      localStorage.setItem(WISHLIST_KEY, JSON.stringify(list));
      showToast('Saved to wishlist');
    }
    syncWishlistBtn();
  });
</script>
