---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="My Addresses | Gladskin">
  <Header />
  <main style="padding-top:3.25rem; min-height:100vh; background:var(--surface);">
    <div style="max-width:48rem; margin:0 auto; padding:1.5rem clamp(1.25rem,4vw,3rem) 3rem;">
      <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; margin-bottom:2rem;">
        <h1 class="font-headline" style="font-size:clamp(1.75rem,3vw,2.25rem); color:var(--on-surface); margin:0;">My Addresses</h1>
        <button id="add-new-btn" style="display:flex; align-items:center; gap:0.5rem; padding:0.7rem 1.25rem; background:var(--primary); color:#fff; border:none; border-radius:9999px; font-family:'Manrope',sans-serif; font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; cursor:pointer;">
          <span class="material-symbols-outlined" style="font-size:1rem;">add</span> Add New
        </button>
      </div>

      <!-- Address list -->
      <div id="address-list" style="display:flex; flex-direction:column; gap:1rem; margin-bottom:2rem;"></div>

      <!-- Empty state -->
      <div id="addr-empty" style="display:none; text-align:center; padding:4rem 0;">
        <span class="material-symbols-outlined" style="font-size:4rem; color:var(--outline-variant); display:block; margin-bottom:1rem;">location_off</span>
        <p style="font-family:'Manrope',sans-serif; color:var(--on-surface-variant); margin:0;">No saved addresses yet.</p>
      </div>

      <!-- Add / Edit form -->
      <div id="address-form-section" style="display:none; background:var(--surface-container-lowest); border:1px solid var(--outline-variant); border-radius:1rem; padding:1.5rem;">
        <h2 id="form-title" style="font-family:'Manrope',sans-serif; font-size:0.8rem; font-weight:800; letter-spacing:0.15em; text-transform:uppercase; color:var(--on-surface); margin:0 0 1.25rem;">New Address</h2>
        <div style="display:grid; gap:1rem;">
          <input type="hidden" id="edit-id" />
          <div class="aform-row-2">
            <div class="afield"><label class="alabel">Full Name *</label><input id="a-name"    type="text"  class="ainput" placeholder="Elena Rossi" /></div>
            <div class="afield"><label class="alabel">Phone *</label>    <input id="a-phone"   type="tel"   class="ainput" placeholder="10-digit" maxlength="10" /></div>
          </div>
          <div class="afield"><label class="alabel">House / Street / Area *</label><input id="a-address" type="text" class="ainput" placeholder="123, Orchid Lane" /></div>
          <div class="aform-row-3">
            <div class="afield"><label class="alabel">City *</label>   <input id="a-city"    type="text" class="ainput" placeholder="Mumbai" /></div>
            <div class="afield"><label class="alabel">State *</label>  <input id="a-state"   type="text" class="ainput" placeholder="Maharashtra" /></div>
            <div class="afield"><label class="alabel">Pincode *</label><input id="a-pincode" type="text" class="ainput" placeholder="400001" maxlength="6" /></div>
          </div>
          <div style="display:flex; gap:0.75rem; justify-content:flex-end; flex-wrap:wrap; margin-top:0.5rem;">
            <button id="cancel-form" style="padding:0.7rem 1.25rem; background:none; border:1.5px solid var(--outline-variant); border-radius:9999px; font-family:'Manrope',sans-serif; font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; cursor:pointer; color:var(--on-surface-variant);">Cancel</button>
            <button id="save-addr"   style="padding:0.7rem 1.5rem;  background:var(--primary); border:none; border-radius:9999px; font-family:'Manrope',sans-serif; font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; cursor:pointer; color:#fff;">Save Address</button>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .aform-row-2 { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
  .aform-row-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:1rem; }
  .afield { display:flex; flex-direction:column; gap:0.4rem; }
  .alabel { font-family:'Manrope',sans-serif; font-size:0.72rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--on-surface-variant); }
  .ainput { padding:0.7rem 1rem; border:1px solid var(--outline-variant); border-radius:0.625rem; font-family:'Manrope',sans-serif; font-size:0.9rem; color:var(--on-surface); background:var(--surface); outline:none; transition:border-color 0.2s; width:100%; box-sizing:border-box; }
  .ainput:focus { border-color:var(--primary); }
  @media (max-width:500px) {
    .aform-row-2, .aform-row-3 { grid-template-columns:1fr !important; }
  }
</style>

<script>
  const ADDR_KEY = 'gladskin_addresses';
  function getAddrs() { try { return JSON.parse(localStorage.getItem(ADDR_KEY)||'[]'); } catch{return[];} }
  function saveAddrs(a: any[]) { localStorage.setItem(ADDR_KEY, JSON.stringify(a)); }

  const listEl    = document.getElementById('address-list')!;
  const emptyEl   = document.getElementById('addr-empty')!;
  const formSec   = document.getElementById('address-form-section')!;
  const formTitle = document.getElementById('form-title')!;
  const editIdEl  = document.getElementById('edit-id') as HTMLInputElement;

  function field(id: string) { return (document.getElementById(id) as HTMLInputElement).value.trim(); }
  function setField(id: string, val: string) { (document.getElementById(id) as HTMLInputElement).value = val; }

  function showToast(msg: string, err = false) {
    let t = document.getElementById('addr-toast');
    if (!t) { t = document.createElement('div'); t.id='addr-toast'; t.style.cssText='position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(4rem);padding:0.75rem 1.5rem;border-radius:9999px;font-family:Manrope,sans-serif;font-size:0.8rem;font-weight:600;opacity:0;transition:all 0.3s;z-index:100;white-space:nowrap;'; document.body.appendChild(t); }
    t.style.background = err ? '#c62828' : 'var(--on-surface)';
    t.style.color = '#fff';
    t.textContent = msg;
    t.style.opacity='1'; t.style.transform='translateX(-50%) translateY(0)';
    setTimeout(()=>{ t!.style.opacity='0'; t!.style.transform='translateX(-50%) translateY(4rem)'; }, 2500);
  }

  function render() {
    const addrs = getAddrs();
    emptyEl.style.display = addrs.length === 0 ? 'block' : 'none';
    listEl.innerHTML = addrs.map((a: any) => `
      <div style="background:var(--surface-container-lowest); border:1px solid var(--outline-variant); border-radius:1rem; padding:1.25rem; display:flex; justify-content:space-between; align-items:flex-start; gap:1rem;">
        <div>
          <div style="font-family:'Manrope',sans-serif; font-weight:700; font-size:0.95rem; color:var(--on-surface); margin-bottom:0.3rem;">${a.name}</div>
          <div style="font-family:'Manrope',sans-serif; font-size:0.82rem; color:var(--on-surface-variant); line-height:1.6;">${a.addressLine}, ${a.city}, ${a.state} – ${a.pincode}<br/>📞 ${a.phone}</div>
        </div>
        <div style="display:flex; gap:0.5rem; flex-shrink:0;">
          <button onclick="window.__editAddr('${a.id}')" style="padding:0.4rem 0.75rem; border:1px solid var(--outline-variant); border-radius:9999px; background:none; cursor:pointer; font-family:'Manrope',sans-serif; font-size:0.7rem; font-weight:600; color:var(--primary); display:flex; align-items:center; gap:0.25rem;">
            <span class="material-symbols-outlined" style="font-size:0.9rem;">edit</span>Edit
          </button>
          <button onclick="window.__deleteAddr('${a.id}')" style="padding:0.4rem 0.75rem; border:1px solid var(--outline-variant); border-radius:9999px; background:none; cursor:pointer; font-family:'Manrope',sans-serif; font-size:0.7rem; font-weight:600; color:#c62828; display:flex; align-items:center; gap:0.25rem;">
            <span class="material-symbols-outlined" style="font-size:0.9rem;">delete</span>
          </button>
        </div>
      </div>
    `).join('');
  }

  function openForm(addr?: any) {
    formSec.style.display = 'block';
    formTitle.textContent  = addr ? 'Edit Address' : 'New Address';
    editIdEl.value         = addr?.id || '';
    setField('a-name',    addr?.name        || '');
    setField('a-phone',   addr?.phone       || '');
    setField('a-address', addr?.addressLine || '');
    setField('a-city',    addr?.city        || '');
    setField('a-state',   addr?.state       || '');
    setField('a-pincode', addr?.pincode     || '');
    formSec.scrollIntoView({ behavior:'smooth', block:'start' });
  }

  function closeForm() {
    formSec.style.display = 'none';
    editIdEl.value = '';
  }

  document.getElementById('add-new-btn')!.addEventListener('click', () => openForm());
  document.getElementById('cancel-form')!.addEventListener('click', closeForm);

  document.getElementById('save-addr')!.addEventListener('click', () => {
    const name=field('a-name'), phone=field('a-phone'), addressLine=field('a-address'),
          city=field('a-city'), state=field('a-state'), pincode=field('a-pincode');
    if (!name||!phone||!addressLine||!city||!state||!pincode) { showToast('Please fill all fields.',true); return; }
    if (!/^\d{10}$/.test(phone))  { showToast('Enter a valid 10-digit phone.',true); return; }
    if (!/^\d{6}$/.test(pincode)) { showToast('Enter a valid 6-digit pincode.',true); return; }

    const addrs = getAddrs();
    const id    = editIdEl.value;
    if (id) {
      const idx = addrs.findIndex((a:any) => a.id === id);
      if (idx > -1) addrs[idx] = { id, name, phone, addressLine, city, state, pincode };
    } else {
      addrs.push({ id:`addr_${Date.now()}`, name, phone, addressLine, city, state, pincode });
    }
    saveAddrs(addrs);
    closeForm();
    render();
    showToast(id ? 'Address updated' : 'Address saved');
  });

  (window as any).__editAddr   = (id: string) => openForm(getAddrs().find((a:any)=>a.id===id));
  (window as any).__deleteAddr = (id: string) => {
    if (!confirm('Delete this address?')) return;
    saveAddrs(getAddrs().filter((a:any)=>a.id!==id));
    render();
    showToast('Address deleted');
  };

  render();
</script>
