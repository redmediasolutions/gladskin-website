---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="My Orders | Gladskin">
  <Header />
  <main style="padding-top:3.25rem; min-height:100vh; background:var(--surface);">
    <div style="max-width:56rem; margin:0 auto; padding:1.5rem clamp(1.25rem,4vw,3rem) 3rem;">

      <h1 class="font-headline" style="font-size:clamp(1.75rem,3vw,2.5rem); color:var(--on-surface); margin:0 0 2rem;">My Orders</h1>

      <!-- Loading -->
      <div id="orders-loading" style="text-align:center; padding:5rem 0;">
        <span class="material-symbols-outlined" style="font-size:2.5rem; color:var(--outline-variant); display:block; margin-bottom:0.5rem; animation:spin 1s linear infinite;">progress_activity</span>
        <p style="font-family:'Manrope',sans-serif; font-size:0.85rem; color:var(--on-surface-variant);">Loading your orders…</p>
      </div>

      <!-- Empty state -->
      <div id="orders-empty" style="display:none; text-align:center; padding:5rem 0;">
        <span class="material-symbols-outlined" style="font-size:4rem; color:var(--outline-variant); display:block; margin-bottom:1rem;">receipt_long</span>
        <p style="font-family:'Manrope',sans-serif; color:var(--on-surface-variant); margin:0 0 1.5rem;">You haven't placed any orders yet.</p>
        <a href="/collection" style="display:inline-block; padding:1rem 2.5rem; background:var(--primary); color:#fff; border-radius:9999px; font-family:'Manrope',sans-serif; font-weight:700; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; text-decoration:none;">Start Shopping</a>
      </div>

      <!-- Orders list -->
      <div id="orders-list" style="display:flex; flex-direction:column; gap:1rem;"></div>
    </div>
  </main>
  <Footer />

  <!-- ── Glassmorphic cancel confirmation modal ── -->
  <div id="cancel-modal" class="modal-backdrop">
    <div class="modal-glass">
      <!-- Diagonal shine sweep (plays on open) -->
      <div class="modal-shine"></div>

      <span class="material-symbols-outlined modal-icon">report_problem</span>
      <h3 class="modal-title">Cancel this order?</h3>
      <p class="modal-body">This cannot be undone. Once cancelled, you'll need to place a new order.</p>

      <div class="modal-actions">
        <button id="modal-confirm-btn" class="modal-btn modal-btn-danger">Yes, Cancel Order</button>
        <button id="modal-dismiss-btn" class="modal-btn modal-btn-ghost">Keep My Order</button>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* ── Spinner ── */
  @keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* ── Modal backdrop ── */
  .modal-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 300;
    align-items: center;
    justify-content: center;
    background: rgba(40, 0, 50, 0.45);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .modal-backdrop.open { display: flex; }

  /* ── Glass card ── */
  .modal-glass {
    position: relative;
    overflow: hidden;
    background: rgba(111, 5, 98, 0.28);
    backdrop-filter: blur(28px) saturate(180%);
    -webkit-backdrop-filter: blur(28px) saturate(180%);
    border: 1px solid rgba(255, 172, 231, 0.35);
    border-radius: 1.5rem;
    padding: 2rem 1.75rem 1.75rem;
    max-width: 21rem;
    width: calc(100% - 2rem);
    box-shadow:
      0 30px 60px rgba(111, 5, 98, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.08) inset;
    animation: modalIn 0.35s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.88) translateY(12px); }
    to   { opacity: 1; transform: scale(1)    translateY(0); }
  }

  /* Diagonal shine sweep */
  .modal-shine {
    position: absolute;
    top: -60%; left: -60%;
    width: 55%; height: 220%;
    background: linear-gradient(
      108deg,
      transparent 30%,
      rgba(255, 255, 255, 0.18) 50%,
      rgba(255, 172, 231, 0.14) 56%,
      transparent 70%
    );
    pointer-events: none;
    animation: shineSweepModal 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
    transform: translateX(-100%);
  }
  @keyframes shineSweepModal {
    from { transform: translateX(-100%); }
    to   { transform: translateX(480%); }
  }

  /* Icon */
  .modal-icon {
    font-size: 2.25rem;
    color: rgba(255, 172, 231, 0.95);
    display: block;
    margin-bottom: 0.875rem;
    font-variation-settings: 'FILL' 1;
  }

  .modal-title {
    font-family: 'Noto Serif', serif;
    font-size: 1.2rem;
    font-weight: 400;
    color: #fff;
    margin: 0 0 0.5rem;
  }
  .modal-body {
    font-family: 'Manrope', sans-serif;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.65;
    margin: 0 0 1.5rem;
  }

  /* Buttons */
  .modal-actions {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .modal-btn {
    width: 100%;
    padding: 0.75rem;
    border-radius: 9999px;
    font-family: 'Manrope', sans-serif;
    font-size: 0.73rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.18s ease;
  }
  .modal-btn-danger {
    background: rgba(220, 38, 38, 0.82);
    border: 1.5px solid rgba(255, 140, 140, 0.45);
    color: #fff;
  }
  .modal-btn-danger:hover {
    background: rgba(220, 38, 38, 1);
    box-shadow: 0 4px 16px rgba(220, 38, 38, 0.45);
  }
  .modal-btn-ghost {
    background: rgba(255, 255, 255, 0.10);
    border: 1.5px solid rgba(255, 255, 255, 0.28);
    color: rgba(255, 255, 255, 0.85);
  }
  .modal-btn-ghost:hover {
    background: rgba(255, 255, 255, 0.18);
  }
</style>

<script>
  import type { User } from 'firebase/auth';
  import { doc, updateDoc } from 'firebase/firestore';
  import { subscribeToAuth } from '../lib/auth';
  import { db } from '../lib/firebase-client';
  import { listOrders, type OrderDoc } from '../lib/firestore-data';

  // ── Status configs ───────────────────────────────────────────────────────
  const WOO_STATUS: Record<string, { color: string; bg: string; icon: string; label: string }> = {
    pending:    { color:'#c9960c', bg:'rgba(201,150,12,0.10)',  icon:'schedule',       label:'Pending' },
    processing: { color:'#1565c0', bg:'rgba(21,101,192,0.10)',  icon:'local_shipping', label:'Processing' },
    completed:  { color:'#2e7d32', bg:'rgba(46,125,50,0.10)',   icon:'check_circle',   label:'Delivered' },
    cancelled:  { color:'#c62828', bg:'rgba(198,40,40,0.10)',   icon:'cancel',         label:'Cancelled' },
    'on-hold':  { color:'#c9960c', bg:'rgba(201,150,12,0.10)', icon:'pause_circle',   label:'On Hold' },
    refunded:   { color:'#6a1b9a', bg:'rgba(106,27,154,0.10)',  icon:'replay',         label:'Refunded' },
    failed:     { color:'#c62828', bg:'rgba(198,40,40,0.10)',   icon:'error',          label:'Failed' },
  };
  const PAY_STATUS: Record<string, { color: string; bg: string; icon: string; label: string }> = {
    paid:    { color:'#2e7d32', bg:'rgba(46,125,50,0.10)',   icon:'check_circle', label:'Paid' },
    pending: { color:'#c9960c', bg:'rgba(201,150,12,0.10)', icon:'schedule',     label:'Awaiting Payment' },
    failed:  { color:'#c62828', bg:'rgba(198,40,40,0.10)',  icon:'cancel',       label:'Payment Failed' },
  };

  let currentUser: User | null = null;

  function formatDate(ts: any) {
    try {
      const date = ts?.toDate ? ts.toDate() : new Date(ts);
      return date.toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' });
    } catch { return ''; }
  }

  function canCancel(order: OrderDoc): boolean {
    const s = (order.status || '').toLowerCase();
    if (s === 'cancelled' || s === 'completed') return false;
    if (!order.createdAt) return false;
    const created = order.createdAt?.toDate ? order.createdAt.toDate() : new Date(order.createdAt);
    return (Date.now() - created.getTime()) / 3_600_000 < 24;
  }

  function badge(cfg: { color: string; bg: string; icon: string; label: string }) {
    return `<span style="background:${cfg.bg}; color:${cfg.color}; font-family:'Manrope',sans-serif; font-size:0.68rem; font-weight:700; padding:0.28rem 0.7rem; border-radius:9999px; display:inline-flex; align-items:center; gap:0.25rem; letter-spacing:0.05em; text-transform:uppercase;">
      <span class="material-symbols-outlined" style="font-size:0.8rem; font-variation-settings:'FILL' 1">${cfg.icon}</span>${cfg.label}
    </span>`;
  }

  function renderOrders(orders: OrderDoc[]) {
    document.getElementById('orders-loading')!.style.display = 'none';
    const emptyEl = document.getElementById('orders-empty')!;
    const listEl  = document.getElementById('orders-list')!;

    if (orders.length === 0) { emptyEl.style.display = 'block'; listEl.innerHTML = ''; return; }
    emptyEl.style.display = 'none';

    listEl.innerHTML = orders.map((order) => {
      // wooOrderId may be absent — try doc ID as fallback, else null
      const rawNum  = order.wooOrderId || Number(order.id);
      const wooId   = (!isNaN(rawNum) && rawNum > 0) ? rawNum : null;
      const docId   = order.id; // Firestore document ID, always a string
      const displayId = wooId ?? docId;

      const wooS    = WOO_STATUS[(order.status || '').toLowerCase()];
      const payS    = PAY_STATUS[order.paymentStatus] || PAY_STATUS.pending;
      const method  = order.paymentMethod === 'cod' ? 'Cash on Delivery' : 'Online Payment';
      const cancellable  = canCancel(order);
      const isCancelled  = (order.status || '').toLowerCase() === 'cancelled';

      const cancelSection = cancellable
        ? `<div style="padding-top:0.75rem; border-top:1px solid var(--outline-variant); margin-top:0.25rem;">
             <button
               onclick="window.__openCancelModal('${docId}', ${wooId ?? 'null'})"
               style="width:100%; padding:0.6rem; background:none; border:1.5px solid #c62828; border-radius:9999px; font-family:'Manrope',sans-serif; font-size:0.72rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; cursor:pointer; color:#c62828; transition:all 0.18s;"
               onmouseover="this.style.background='rgba(198,40,40,0.06)'"
               onmouseout="this.style.background='none'"
             >Cancel Order</button>
             <p style="font-family:'Manrope',sans-serif; font-size:0.65rem; color:var(--on-surface-variant); text-align:center; margin:0.35rem 0 0;">Can be cancelled within 24 hours of placing</p>
           </div>`
        : (!isCancelled && order.createdAt
            ? `<p style="font-family:'Manrope',sans-serif; font-size:0.65rem; color:#9a8a94; text-align:center; padding-top:0.6rem; border-top:1px solid var(--outline-variant); margin-top:0.25rem; margin-bottom:0;">Cancellation window has expired</p>`
            : '');

      return `
        <div data-order-id="${docId}"
          style="background:var(--surface-container-lowest); border:1px solid var(--outline-variant); border-radius:1rem; padding:1.25rem; transition:box-shadow 0.2s;"
          onmouseover="this.style.boxShadow='0 4px 20px rgba(111,5,98,0.08)'"
          onmouseout="this.style.boxShadow='none'">

          <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:0.5rem; margin-bottom:0.875rem;">
            <div>
              <div style="font-family:'Manrope',sans-serif; font-size:0.72rem; color:var(--on-surface-variant); letter-spacing:0.08em; text-transform:uppercase; margin-bottom:0.15rem;">Order #${displayId}</div>
              <div style="font-family:'Manrope',sans-serif; font-size:0.78rem; color:var(--on-surface-variant);">${formatDate(order.createdAt)}</div>
            </div>
            <div style="display:flex; flex-wrap:wrap; gap:0.4rem; align-items:center;">
              ${wooS ? badge(wooS) : badge(payS)}
            </div>
          </div>

          <div style="display:flex; flex-direction:column; gap:0.35rem; padding-top:0.75rem; border-top:1px solid var(--outline-variant);">
            <div style="display:flex; justify-content:space-between; font-family:'Manrope',sans-serif; font-size:0.8rem; color:var(--on-surface-variant);">
              <span>Subtotal</span><span>₹${Number(order.subtotal || 0).toFixed(0)}</span>
            </div>
            <div style="display:flex; justify-content:space-between; font-family:'Manrope',sans-serif; font-size:0.8rem; color:var(--on-surface-variant);">
              <span>Shipping</span>
              <span style="color:${order.shipping === 0 ? 'var(--tertiary)' : 'inherit'}; font-weight:${order.shipping === 0 ? '700' : '400'}">
                ${order.shipping === 0 ? 'FREE' : '₹' + Number(order.shipping || 0).toFixed(0)}
              </span>
            </div>
            <div style="display:flex; justify-content:space-between; font-family:'Manrope',sans-serif; font-size:0.8rem; color:var(--on-surface-variant);">
              <span>Tax (GST 5%)</span><span>₹${Number(order.tax || 0).toFixed(0)}</span>
            </div>
            ${Number(order.codCharge) > 0 ? `
            <div style="display:flex; justify-content:space-between; font-family:'Manrope',sans-serif; font-size:0.8rem; color:var(--on-surface-variant);">
              <span>COD Charge</span><span>₹${Number(order.codCharge).toFixed(0)}</span>
            </div>` : ''}
            <div style="display:flex; justify-content:space-between; font-family:'Noto Serif',serif; font-size:1rem; color:var(--on-surface); border-top:1px solid var(--outline-variant); padding-top:0.5rem; margin-top:0.15rem;">
              <span>Total Paid</span><span>₹${Number(order.finalPayable || 0).toFixed(0)}</span>
            </div>
            <div style="font-family:'Manrope',sans-serif; font-size:0.72rem; color:var(--on-surface-variant); display:flex; align-items:center; gap:0.3rem; margin-top:0.1rem;">
              <span class="material-symbols-outlined" style="font-size:0.9rem;">payments</span>${method}
            </div>
          </div>

          ${cancelSection}
        </div>
      `;
    }).join('');
  }

  function showToast(msg: string, err = false) {
    let t = document.getElementById('orders-toast');
    if (!t) {
      t = document.createElement('div');
      t.id = 'orders-toast';
      t.style.cssText = 'position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(4rem);padding:0.75rem 1.5rem;border-radius:9999px;font-family:Manrope,sans-serif;font-size:0.8rem;font-weight:600;opacity:0;transition:all 0.3s;z-index:400;white-space:nowrap;pointer-events:none;';
      document.body.appendChild(t);
    }
    t.style.background = err ? '#c62828' : 'var(--on-surface)';
    t.style.color = '#fff';
    t.textContent = msg;
    t.style.opacity = '1';
    t.style.transform = 'translateX(-50%) translateY(0)';
    setTimeout(() => {
      t!.style.opacity = '0';
      t!.style.transform = 'translateX(-50%) translateY(4rem)';
    }, 3500);
  }

  function loadOrders(uid: string) {
    listOrders(uid).then(renderOrders).catch(() => renderOrders([]));
  }

  // ── Cancel modal ─────────────────────────────────────────────────────────
  const modal        = document.getElementById('cancel-modal')!;
  const confirmBtn   = document.getElementById('modal-confirm-btn')!;
  const dismissBtn   = document.getElementById('modal-dismiss-btn')!;
  let pendingDocId: string | null = null;   // Firestore document ID (always set)
  let pendingWooId: number | null = null;   // WooCommerce order ID (may be null)

  function openModal(docId: string, wooId: number | null) {
    pendingDocId = docId;
    pendingWooId = wooId;
    // Re-trigger shine animation each open
    const shine = modal.querySelector<HTMLElement>('.modal-shine');
    if (shine) { shine.style.animation = 'none'; requestAnimationFrame(() => { shine.style.animation = ''; }); }
    modal.classList.add('open');
  }
  function closeModal() {
    modal.classList.remove('open');
    pendingDocId = null;
    pendingWooId = null;
  }

  // Close on backdrop click
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  dismissBtn.addEventListener('click', closeModal);

  confirmBtn.addEventListener('click', async () => {
    if (!currentUser || pendingDocId === null) return;
    const docId  = pendingDocId;
    const wooId  = pendingWooId;
    closeModal();
    showToast('Cancelling order…');

    // If there's no valid WooCommerce ID, update Firestore directly
    if (!wooId) {
      try {
        await updateDoc(doc(db, 'Orders', docId), { status: 'cancelled' });
        showToast('Order cancelled successfully');
      } catch {
        showToast('Order removed from your active orders');
      }
      loadOrders(currentUser.uid);
      return;
    }

    try {
      const idToken = await currentUser.getIdToken();
      const res  = await fetch('/api/cancel-order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${idToken}` },
        body: JSON.stringify({ orderId: wooId }),
      });
      const data = await res.json();

      // Order exists in Firestore but not in WooCommerce (deleted / test order).
      // Try to mark it cancelled directly via the Firebase SDK.
      if (data.wooNotFound) {
        try {
          await updateDoc(doc(db, 'Orders', docId), { status: 'cancelled' });
          showToast('Order cancelled successfully');
        } catch {
          showToast('Order removed from your active orders');
        }
        loadOrders(currentUser.uid);
        return;
      }

      if (!res.ok) throw new Error(data.error || 'Cancel failed');
      showToast('Order cancelled successfully');
      loadOrders(currentUser.uid);
    } catch (e: any) {
      showToast(e.message || 'Failed to cancel order', true);
    }
  });

  (window as any).__openCancelModal = openModal;

  // ── Auth gate ─────────────────────────────────────────────────────────────
  subscribeToAuth(user => {
    currentUser = user;
    if (!user) { window.location.href = '/login?next=/orders'; return; }
    loadOrders(user.uid);
  });
</script>
