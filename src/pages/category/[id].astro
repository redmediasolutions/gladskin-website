---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ProductCard from "../../components/ProductCard.astro";
import CategoryNav from "../../components/CategoryNav.astro";

import { getProducts } from "../../data/products";

import {
  fetchLiveCategories,
  fetchCategoryById,
    fetchProductsByCategory,
} from "../../lib/woocommerce";

const { id } = Astro.params;

const categoryId = parseInt(
  id || "49",
  10,
);

const primaryCategories =
  await fetchLiveCategories();

const allProducts =
  await getProducts();

/* ----------------------------------
   FIND PARENT CATEGORY
----------------------------------- */

let parentCategoryId =
  categoryId;

const isPrimaryCategory =
  primaryCategories.some(
    (c) => c.id === categoryId,
  );

if (
  categoryId !== 49 &&
  !isPrimaryCategory
) {
  const category =
    await fetchCategoryById(
      categoryId,
    );

  if (category?.parent) {
    parentCategoryId =
      category.parent;
  }
}

/* ----------------------------------
   PRODUCTS
----------------------------------- */

const products =
  categoryId === 49
    ? await getProducts()
    : await fetchProductsByCategory(
        categoryId,
      );
/* ----------------------------------
   CATEGORY NAME
----------------------------------- */

let categoryName =
  "Products";

if (
  isPrimaryCategory
) {
  categoryName =
    primaryCategories.find(
      (c) =>
        c.id ===
        categoryId,
    )?.name ||
    "Products";
} else {
  const category =
    await fetchCategoryById(
      categoryId,
    );

  categoryName =
    category?.name ||
    "Products";
}
---

<BaseLayout title={`${categoryName} | Gladskin`}>
  <Header />

  <main class="collection-main">

    <div class="collection-hero">
      <div class="collection-hero-inner">
        <div>
          <p class="collection-eyebrow">
            Category
          </p>

          <h1 class="collection-title font-headline">
            {categoryName}
          </h1>
        </div>
      </div>
    </div>

    <div class="collection-body">

      <CategoryNav
        selectedId={parentCategoryId}
        activeSubCategoryId={categoryId}
      />

      <p class="result-count">
        {products.length} products
      </p>

      {
        products.length === 0 ? (
          <div class="empty-state">
            No products found.
          </div>
        ) : (
          <div class="products-grid">
            {products.map(
              (product, i) => (
                <div
                  class="product-item"
                  style={`animation-delay:${Math.min(
                    i * 40,
                    240,
                  )}ms`}
                >
                  <ProductCard
                    product={product}
                  />
                </div>
              ),
            )}
          </div>
        )
      }
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .collection-main {
    min-height: 100vh;
    background: var(--surface);
    padding-top: 3.25rem;
  }

  .collection-hero {
    background:
      linear-gradient(
        135deg,
        var(--surface-container-low) 0%,
        var(--surface) 100%
      );

    border-bottom: 1px solid
      var(--outline-variant);

    padding: 2rem
      clamp(
        1.25rem,
        4vw,
        3rem
      )
      1.5rem;
  }

  .collection-hero-inner {
    max-width: 80rem;
    margin: 0 auto;
  }

  .collection-eyebrow {
    font-family: 'Manrope',
      sans-serif;

    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.3em;
    text-transform: uppercase;

    color: var(--secondary);
  }

  .collection-title {
    margin: 0;

    font-size: clamp(
      1.75rem,
      3vw,
      2.75rem
    );
  }

  .collection-body {
    max-width: 80rem;
    margin: 0 auto;

    padding: 1.5rem
      clamp(
        1.25rem,
        4vw,
        3rem
      )
      3rem;
  }

  .result-count {
    margin: 1rem 0 1.5rem;

    font-family: 'Manrope',
      sans-serif;

    color: var(
      --on-surface-variant
    );
  }

  .products-grid {
    display: grid;

    grid-template-columns:
      repeat(2, 1fr);

    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .products-grid {
      grid-template-columns:
        repeat(3, 1fr);
    }
  }

  @media (min-width: 1280px) {
    .products-grid {
      grid-template-columns:
        repeat(4, 1fr);
    }
  }

  .empty-state {
    padding: 4rem 0;
    text-align: center;
    color: var(
      --on-surface-variant
    );
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform:
        translateY(
          16px
        );
    }

    to {
      opacity: 1;
      transform:
        translateY(0);
    }
  }

  .product-item {
    animation:
      fadeUp
      0.4s
      ease
      both;
  }
</style>