---
import type { Product } from '../types/index.ts';

interface Props {
  product: Product;
  delay?: number;
}

const { product, delay = 0 } = Astro.props;

const discountPercent = product.originalPrice && product.originalPrice > product.price
  ? Math.round(((product.originalPrice - product.price) / product.originalPrice) * 100)
  : null;
---

<div class="product-card">

  <!-- Image -->
  <div class="product-image-wrap">
    <img
      src={product.image}
      alt={product.imageAlt || product.name}
      loading="lazy"
      decoding="async"
    />
    {discountPercent !== null && (
      <span class="badge-discount">{discountPercent}% OFF</span>
    )}
    {product.badge && !discountPercent && (
      <span class="badge-featured">{product.badge}</span>
    )}
    <div class="hover-overlay">
      <span>View Detail</span>
    </div>
  </div>

  <!-- Info -->
  <div class="product-info">
    <p class="product-cat">{product.category}</p>
    <h3 class="product-name">{product.name}</h3>
    <div class="price-row">
      <span class="price-now">₹{product.price.toFixed(0)}</span>
      {product.originalPrice && product.originalPrice > product.price && (
        <span class="price-was">₹{product.originalPrice.toFixed(0)}</span>
      )}
    </div>
    {discountPercent !== null && product.originalPrice && (
      <p class="price-save">You save ₹{(product.originalPrice - product.price).toFixed(0)}</p>
    )}
  </div>

  <!-- Stretched link makes the whole card clickable -->
  <a href={`/products/${product.slug}`} class="card-link" aria-label={product.name}></a>
</div>

<style>
  /* ── Card shell ── */
  .product-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: 1rem;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 1px 6px rgba(0,0,0,0.07), 0 4px 16px rgba(111,5,98,0.05);
    transition: box-shadow 0.32s ease, transform 0.32s cubic-bezier(0.22,1,0.36,1);
    transform-origin: bottom center;
  }
  .product-card:hover {
    transform: translateY(-7px) rotate(2deg);
    box-shadow:
      0 16px 40px rgba(0,0,0,0.10),
      0 0 0 2px rgba(230, 140, 210, 0.85),
      0 0 18px rgba(230, 140, 210, 0.45),
      0 0 36px rgba(200, 100, 180, 0.20),
      0 6px 20px rgba(111,5,98,0.12);
  }

  /* Stretched link overlay — entire card becomes clickable */
  .card-link {
    position: absolute;
    inset: 0;
    z-index: 2;
    border-radius: 1rem;
  }

  /* ── Image ── */
  .product-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f7f4f6;
    flex-shrink: 0;
  }
  .product-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 0.625rem;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    display: block;
  }
  .product-card:hover .product-image-wrap img {
    transform: scale(1.06);
  }

  /* Hover overlay — glassmorphic purple with shine */
  .hover-overlay {
    position: absolute;
    inset: 0;
    background: rgba(111, 5, 98, 0.35);
    backdrop-filter: blur(10px) saturate(180%);
    -webkit-backdrop-filter: blur(10px) saturate(180%);
    border: 1px solid rgba(255, 172, 231, 0.3);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    opacity: 0;
    transition: opacity 0.3s ease;
    overflow: hidden;
  }
  /* Diagonal shine sweep */
  .hover-overlay::before {
    content: '';
    position: absolute;
    top: -60%;
    left: -60%;
    width: 60%;
    height: 200%;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(255, 255, 255, 0.22) 50%,
      rgba(255, 172, 231, 0.18) 55%,
      transparent 70%
    );
    transform: translateX(-100%);
    transition: none;
    pointer-events: none;
  }
  .product-card:hover .hover-overlay::before {
    animation: shineSweep 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.05s forwards;
  }
  @keyframes shineSweep {
    from { transform: translateX(-100%); }
    to   { transform: translateX(420%); }
  }
  .hover-overlay span {
    position: relative;
    z-index: 1;
    color: #fff;
    font-family: 'Manrope', sans-serif;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    background: rgba(111, 5, 98, 0.6);
    padding: 0.55rem 1.4rem;
    border-radius: 9999px;
    border: 1.5px solid rgba(235, 210, 235, 0.65);
    box-shadow:
      0 2px 18px rgba(111, 5, 98, 0.4),
      0 0 0 1px rgba(255,255,255,0.15) inset;
    backdrop-filter: blur(4px);
  }
  .product-card:hover .hover-overlay {
    opacity: 1;
  }

  /* Badges */
  .badge-discount,
  .badge-featured {
    position: absolute;
    top: 0.6rem;
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: 'Manrope', sans-serif;
    padding: 0.18rem 0.55rem;
    border-radius: 9999px;
    z-index: 1;
    line-height: 1.6;
  }
  .badge-discount {
    left: 0.6rem;
    background: #1a1a1a;
    color: #fff;
  }
  .badge-featured {
    right: 0.6rem;
    background: #c9f089;
    color: #1a2e00;
  }

  /* ── Info ── */
  .product-info {
    padding: 0.75rem 0.875rem 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    border-top: 1px solid #f0ecee;
    flex: 1;
  }
  .product-cat {
    font-family: 'Manrope', sans-serif;
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--primary);
    margin: 0;
  }
  .product-name {
    font-family: 'Noto Serif', serif;
    font-size: 0.92rem;
    font-weight: 400;
    color: #1a1a1c;
    margin: 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .price-row {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    margin-top: 0.3rem;
  }
  .price-now {
    font-family: 'Manrope', sans-serif;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--primary);
  }
  .price-was {
    font-family: 'Manrope', sans-serif;
    font-size: 0.72rem;
    color: #9a8a94;
    text-decoration: line-through;
  }
  .price-save {
    font-family: 'Manrope', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    color: #B34E6F;
    margin: 0.1rem 0 0;
  }
</style>
