---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getProductBySlug, getProducts } from '../../data/products.ts';

const { slug } = Astro.params;
const product = await getProductBySlug(slug!);

if (!product) {
  return Astro.redirect('/collection');
}
---

<BaseLayout title={`${product.name} | Gladskin`} description={`Discover ${product.name} – ${product.category}`}>
  <Header />
  <main style="padding-top:8rem; min-height:100vh; background:var(--surface);">
    <div style="max-width:80rem; margin:0 auto; padding:4rem 3rem;">
      <a href="/collection" style="display:inline-flex; align-items:center; gap:0.5rem; font-family:'Manrope',sans-serif; font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:var(--on-surface-variant); text-decoration:none; margin-bottom:3rem; transition:color 0.3s;" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--on-surface-variant)'">
        <span class="material-symbols-outlined" style="font-size:1.125rem;">arrow_back</span>
        Back to Collection
      </a>

      <div class="product-detail-grid">
        <!-- Image -->
        <div style="border-radius:1rem; overflow:hidden; background:var(--surface-container); aspect-ratio:3/4; max-height:700px;">
          <img src={product.image} alt={product.imageAlt} style="width:100%; height:100%; object-fit:cover;" />
        </div>

        <!-- Info -->
        <div style="display:flex; flex-direction:column; justify-content:center; gap:2rem;">
          <div>
            <span style="background:rgba(201,240,137,0.3); color:var(--on-tertiary-fixed-variant); padding:0.25rem 0.75rem; border-radius:9999px; font-size:0.65rem; font-weight:700; text-transform:uppercase; letter-spacing:0.15em; font-family:'Manrope',sans-serif;">{product.category}</span>
          </div>
          <h1 class="font-headline" style="font-size:clamp(2rem,4vw,3.5rem); color:var(--on-surface); margin:0; line-height:1.1;">{product.name}</h1>
          <p style="font-family:'Manrope',sans-serif; font-size:2rem; color:var(--primary); font-weight:300; margin:0;">₹{product.price.toFixed(2)}</p>
          <p class="font-body" style="color:var(--on-surface-variant); line-height:1.8; font-size:1.1rem; margin:0;">
            A rare botanical formulation crafted from the finest Vanda orchid extracts. Each drop delivers concentrated cellular intelligence to transform your skin's natural repair architecture.
          </p>

          <!-- Add to Cart -->
          <div style="display:flex; flex-direction:column; gap:1rem;">
            <div style="display:flex; align-items:center; gap:1rem;">
              <label style="font-family:'Manrope',sans-serif; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.15em; color:var(--on-surface-variant);">Quantity</label>
              <div style="display:flex; align-items:center; border:1px solid var(--outline-variant); border-radius:9999px; overflow:hidden;">
                <button id="qty-minus" style="padding:0.5rem 1rem; background:none; border:none; cursor:pointer; font-size:1.25rem; color:var(--on-surface);">−</button>
                <span id="qty-display" style="padding:0.5rem 1rem; font-family:'Manrope',sans-serif; font-weight:600; min-width:2.5rem; text-align:center;">1</span>
                <button id="qty-plus" style="padding:0.5rem 1rem; background:none; border:none; cursor:pointer; font-size:1.25rem; color:var(--on-surface);">+</button>
              </div>
            </div>
            <button
              id="add-to-cart"
              data-product-id={product.id}
              style="padding:1.25rem 2.5rem; background:linear-gradient(135deg,var(--primary),var(--primary-container)); color:var(--on-primary); border:none; border-radius:9999px; font-family:'Manrope',sans-serif; font-weight:700; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; cursor:pointer; transition:transform 0.2s,box-shadow 0.2s; box-shadow:0 8px 24px rgba(111,5,98,0.2);"
              onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 12px 32px rgba(111,5,98,0.3)'"
              onmouseout="this.style.transform='';this.style.boxShadow='0 8px 24px rgba(111,5,98,0.2)'"
            >
              Add to Bag
            </button>
          </div>

          <!-- Features -->
          <div style="border-top:1px solid var(--outline-variant); padding-top:2rem; display:grid; grid-template-columns:1fr 1fr; gap:1.5rem;">
            {[
              { icon: 'eco', label: 'Botanical Certified' },
              { icon: 'science', label: 'Lab Tested' },
              { icon: 'local_shipping', label: 'Free Shipping' },
              { icon: 'recycling', label: 'Eco Packaging' },
            ].map(f => (
              <div style="display:flex; align-items:center; gap:0.75rem;">
                <span class="material-symbols-outlined" style="color:var(--primary); font-size:1.25rem;">{f.icon}</span>
                <span style="font-family:'Manrope',sans-serif; font-size:0.8rem; color:var(--on-surface-variant); font-weight:600;">{f.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .product-detail-grid { display:grid; grid-template-columns:1fr; gap:4rem; }
  @media (min-width:768px) { .product-detail-grid { grid-template-columns:1fr 1fr; } }
</style>

<script>
  let qty = 1;
  const display = document.getElementById('qty-display')!;
  document.getElementById('qty-minus')?.addEventListener('click', () => { if (qty > 1) { qty--; display.textContent = String(qty); } });
  document.getElementById('qty-plus')?.addEventListener('click', () => { qty++; display.textContent = String(qty); });

  document.getElementById('add-to-cart')?.addEventListener('click', () => {
    // TODO: call POST /api/cart with { productId, quantity: qty }
    const countEl = document.getElementById('cart-count');
    if (countEl) countEl.textContent = String(Number(countEl.textContent) + qty);
  });
</script>
