---
---

<footer style="background:var(--surface-container-low); border-top:none;">
  <div style="display:grid; grid-template-columns:1fr; gap:3rem; padding:6rem 3rem; max-width:80rem; margin:0 auto;" class="footer-grid">
    <!-- Brand -->
    <div>
      <span style="font-family:'Noto Serif',serif; font-size:1.5rem; color:var(--primary); display:block; margin-bottom:1.5rem; text-transform:uppercase; letter-spacing:0.3em;">Gladskin</span>
      <p style="font-family:'Manrope',sans-serif; color:var(--on-surface-variant); max-width:18rem; line-height:1.7;">
        Curating the world's most potent botanicals for a life of radiant longevity.
      </p>
    </div>

    <!-- Maison -->
    <div>
      <h5 style="font-family:'Manrope',sans-serif; font-weight:800; font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--on-surface); margin-bottom:1.5rem;">Maison</h5>
      <div style="display:flex; flex-direction:column; gap:1rem;">
        {['Atelier','Collection','Ritual'].map(item => (
          <a href={`/${item.toLowerCase()}`} style="font-family:'Manrope',sans-serif; font-size:1rem; color:var(--on-surface-variant); text-decoration:none; transition:all 0.3s;" onmouseover="this.style.color='var(--on-surface)'; this.style.paddingLeft='4px'" onmouseout="this.style.color='var(--on-surface-variant)'; this.style.paddingLeft='0'">{item}</a>
        ))}
      </div>
    </div>

    <!-- Concierge -->
    <div>
      <h5 style="font-family:'Manrope',sans-serif; font-weight:800; font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--on-surface); margin-bottom:1.5rem;">Concierge</h5>
      <div style="display:flex; flex-direction:column; gap:1rem;">
        {[
          { label: 'Sitemap', href: '/sitemap' },
          { label: 'Privacy Policy', href: '/privacy' },
          { label: 'Terms of Service', href: '/terms' },
          { label: 'Shipping & Returns', href: '/shipping' },
        ].map(item => (
          <a href={item.href} style="font-family:'Manrope',sans-serif; font-size:1rem; color:var(--on-surface-variant); text-decoration:none; transition:all 0.3s;" onmouseover="this.style.color='var(--on-surface)'; this.style.paddingLeft='4px'" onmouseout="this.style.color='var(--on-surface-variant)'; this.style.paddingLeft='0'">{item.label}</a>
        ))}
      </div>
    </div>

    <!-- Newsletter -->
    <div>
      <h5 style="font-family:'Manrope',sans-serif; font-weight:800; font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--on-surface); margin-bottom:1.5rem;">Newsletter</h5>
      <p style="font-family:'Manrope',sans-serif; font-size:0.875rem; color:var(--on-surface-variant); margin-bottom:1rem;">Join our inner circle for exclusive botanical insights.</p>
      <form id="newsletter-form" style="position:relative;" method="POST" action="/api/newsletter">
        <input
          type="email"
          name="email"
          placeholder="Email Address"
          required
          style="width:100%; background:transparent; border:none; border-bottom:1px solid var(--outline-variant); padding:0.75rem 2rem 0.75rem 0; font-family:'Manrope',sans-serif; color:var(--on-surface); outline:none; font-size:0.95rem; transition:border-color 0.3s;"
          onfocus="this.style.borderBottomColor='var(--primary)'"
          onblur="this.style.borderBottomColor='var(--outline-variant)'"
        />
        <button type="submit" style="position:absolute; right:0; bottom:0.75rem; background:none; border:none; cursor:pointer; color:var(--primary);" aria-label="Subscribe">
          <span class="material-symbols-outlined">chevron_right</span>
        </button>
      </form>
    </div>
  </div>

  <!-- Bottom bar -->
  <div style="padding:2rem 3rem; border-top:1px solid rgba(215,192,205,0.2); display:flex; flex-direction:column; gap:1rem; align-items:center; max-width:80rem; margin:0 auto;" class="footer-bottom">
    <p style="font-family:'Manrope',sans-serif; font-size:0.875rem; color:var(--on-surface-variant);">© 2024 Gladskin. Crafted with botanical wisdom.</p>
    <div style="display:flex; gap:1.5rem;">
      <a href="#" aria-label="Website" style="color:var(--on-surface-variant); text-decoration:none; transition:color 0.3s;" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--on-surface-variant)'">
        <span class="material-symbols-outlined">public</span>
      </a>
      <a href="#" aria-label="Instagram" style="color:var(--on-surface-variant); text-decoration:none; transition:color 0.3s;" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--on-surface-variant)'">
        <span class="material-symbols-outlined">camera</span>
      </a>
    </div>
  </div>
</footer>

<style>
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(4, 1fr) !important;
    }
    .footer-bottom {
      flex-direction: row !important;
      justify-content: space-between !important;
    }
  }
</style>
