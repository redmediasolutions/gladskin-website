---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Your Bag | Gladskin">
  <Header />
  <main style="padding-top:8rem; min-height:100vh; background:var(--surface);">
    <div style="max-width:64rem; margin:0 auto; padding:4rem 3rem;">
      <h1 class="font-headline" style="font-size:clamp(2rem,4vw,3rem); color:var(--on-surface); margin:0 0 3rem;">Your Bag</h1>

      <div id="cart-empty" style="text-align:center; padding:6rem 0;">
        <span class="material-symbols-outlined" style="font-size:4rem; color:var(--outline-variant); display:block; margin-bottom:1.5rem;">shopping_bag</span>
        <p class="font-body" style="color:var(--on-surface-variant); font-size:1.125rem; margin:0 0 2rem;">Your bag is empty.</p>
        <a href="/collection" style="display:inline-block; padding:1rem 2.5rem; background:var(--primary); color:var(--on-primary); border-radius:9999px; font-family:'Manrope',sans-serif; font-weight:700; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; text-decoration:none;">
          Explore Collection
        </a>
      </div>

      <!-- TODO: Render cart items fetched from /api/cart -->
    </div>
  </main>
  <Footer />
</BaseLayout>
