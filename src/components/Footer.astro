---
---

<footer class="site-footer">
  <div class="footer-inner">

    <img src="/app-header.svg" alt="Gladskin" class="footer-logo" />
    <p class="footer-tagline">Science-backed skincare for radiant skin.</p>

    <div class="footer-rule"></div>

    <nav class="footer-nav">
      <a href="/collection" class="footer-link">Collection</a>
      <span class="footer-dot"></span>
      <a href="/ritual" class="footer-link">Ritual</a>
    </nav>

    <p class="footer-copy">© 2024 Gladskin. All rights reserved.</p>

  </div>
</footer>

<style>
  .site-footer {
    background: var(--surface-container-low);
    border-top: 1px solid var(--outline-variant);
  }

  .footer-inner {
    max-width: 40rem;
    margin: 0 auto;
    padding: 1.5rem clamp(1.25rem, 4vw, 3rem) 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    text-align: center;
  }

  .footer-logo {
    display: block;
    height: 30px;
    width: auto;
    max-width: 140px;
    object-fit: contain;
    margin-bottom: 0.4rem;
  }

  .footer-tagline {
    font-family: 'Manrope', sans-serif;
    font-size: 0.77rem;
    color: var(--on-surface-variant);
    margin: 0;
    opacity: 0.7;
    letter-spacing: 0.02em;
  }

  .footer-rule {
    width: 3rem;
    height: 1.5px;
    background: linear-gradient(90deg, transparent, var(--primary), transparent);
    margin: 0.875rem 0;
    border-radius: 9999px;
  }

  .footer-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.875rem;
  }

  .footer-link {
    font-family: 'Manrope', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--on-surface-variant);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-link:hover { color: var(--primary); }

  .footer-dot {
    display: block;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--outline-variant);
    flex-shrink: 0;
  }

  .footer-copy {
    font-family: 'Manrope', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--on-surface-variant);
    margin: 0;
    border-top: 1px solid var(--outline-variant);
    padding-top: 0.75rem;
    width: 100%;
  }
</style>
