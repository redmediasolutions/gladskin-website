---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getProductBySlug, getProducts } from '../../data/products.ts';

const { slug } = Astro.params;
const product = await getProductBySlug(slug!);

if (!product) {
  return Astro.redirect('/collection');
}
---

<BaseLayout title={`${product.name} | Gladskin`} description={`Discover ${product.name} – ${product.category}`}>
  <Header />
  <main style="padding-top:3.25rem; min-height:100vh; background:var(--surface);">
    <div style="max-width:80rem; margin:0 auto; padding:0 clamp(1.25rem,4vw,3rem) 2rem;">
      <a href="/collection" style="display:inline-flex; align-items:center; gap:0.5rem; font-family:'Manrope',sans-serif; font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:var(--on-surface-variant); text-decoration:none; margin-bottom:3rem; transition:color 0.3s;" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--on-surface-variant)'">
        <span class="material-symbols-outlined" style="font-size:1.125rem;">arrow_back</span>
        Back to Collection
      </a>

      <div class="product-detail-grid">
        <!-- Image -->
        <div style="border-radius:1rem; overflow:hidden; background:var(--surface-container); aspect-ratio:3/4; max-height:700px;">
          <img src={product.image} alt={product.imageAlt} style="width:100%; height:100%; object-fit:cover;" />
        </div>

        <!-- Info -->
        <div style="display:flex; flex-direction:column; justify-content:center; gap:2rem;">
          <div>
            <span style="background:rgba(201,240,137,0.3); color:var(--on-tertiary-fixed-variant); padding:0.25rem 0.75rem; border-radius:9999px; font-size:0.65rem; font-weight:700; text-transform:uppercase; letter-spacing:0.15em; font-family:'Manrope',sans-serif;">{product.category}</span>
          </div>
          <h1 class="font-headline" style="font-size:clamp(2rem,4vw,3.5rem); color:var(--on-surface); margin:0; line-height:1.1;">{product.name}</h1>
          <p style="font-family:'Manrope',sans-serif; font-size:2rem; color:var(--primary); font-weight:300; margin:0;">₹{product.price.toFixed(2)}</p>
          <p class="font-body" style="color:var(--on-surface-variant); line-height:1.8; font-size:1.1rem; margin:0;">
            {product.description || 'A rare botanical formulation crafted from the finest Vanda orchid extracts. Each drop delivers concentrated cellular intelligence to transform your skin\'s natural repair architecture.'}
          </p>

          <!-- Stock badge -->
          {product.inStock === false && (
            <div style="display:inline-flex; align-items:center; gap:0.5rem; background:rgba(198,40,40,0.08); color:#c62828; border-radius:9999px; padding:0.4rem 1rem; font-family:'Manrope',sans-serif; font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase;">
              <span class="material-symbols-outlined" style="font-size:1rem;">cancel</span> Out of Stock
            </div>
          )}

          <!-- Add to Cart -->
          <div style="display:flex; flex-direction:column; gap:1rem;">
            <div style="display:flex; align-items:center; gap:1rem;">
              <label style="font-family:'Manrope',sans-serif; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.15em; color:var(--on-surface-variant);">Quantity</label>
              <div style="display:flex; align-items:center; border:1px solid var(--outline-variant); border-radius:9999px; overflow:hidden;">
                <button id="qty-minus" style="padding:0.5rem 1rem; background:none; border:none; cursor:pointer; font-size:1.25rem; color:var(--on-surface);">−</button>
                <span id="qty-display" style="padding:0.5rem 1rem; font-family:'Manrope',sans-serif; font-weight:600; min-width:2.5rem; text-align:center;">1</span>
                <button id="qty-plus" style="padding:0.5rem 1rem; background:none; border:none; cursor:pointer; font-size:1.25rem; color:var(--on-surface);">+</button>
              </div>
            </div>
            <button
              id="add-to-cart"
              data-product-id={product.id}
              style="padding:1.25rem 2.5rem; background:linear-gradient(135deg,var(--primary),var(--primary-container)); color:var(--on-primary); border:none; border-radius:9999px; font-family:'Manrope',sans-serif; font-weight:700; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; cursor:pointer; transition:transform 0.2s,box-shadow 0.2s; box-shadow:0 8px 24px rgba(111,5,98,0.2);"
              onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 12px 32px rgba(111,5,98,0.3)'"
              onmouseout="this.style.transform='';this.style.boxShadow='0 8px 24px rgba(111,5,98,0.2)'"
            >
              Add to Bag
            </button>
            <button
              id="add-to-wishlist"
              data-product-id={product.id}
              data-product={JSON.stringify({ id: product.id, name: product.name, price: product.price, image: product.image, imageAlt: product.imageAlt, slug: product.slug, category: product.category })}
              style="padding:1.25rem 2.5rem; background:transparent; color:var(--primary); border:1.5px solid var(--primary); border-radius:9999px; font-family:'Manrope',sans-serif; font-weight:700; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; cursor:pointer; transition:all 0.2s; display:flex; align-items:center; justify-content:center; gap:0.5rem;"
              onmouseover="if(!this.classList.contains('saved')){this.style.background='rgba(111,5,98,0.06)'}"
              onmouseout="if(!this.classList.contains('saved')){this.style.background='transparent'}"
            >
              <span class="material-symbols-outlined" id="wishlist-icon" style="font-size:1.1rem;">favorite_border</span>
              <span id="wishlist-label">Save to Wishlist</span>
            </button>
          </div>

          <!-- Features -->
          <div style="border-top:1px solid var(--outline-variant); padding-top:2rem; display:grid; grid-template-columns:1fr 1fr; gap:1.5rem;">
            {[
              { icon: 'eco', label: 'Botanical Certified' },
              { icon: 'science', label: 'Lab Tested' },
              { icon: 'local_shipping', label: 'Free Shipping' },
              { icon: 'recycling', label: 'Eco Packaging' },
            ].map(f => (
              <div style="display:flex; align-items:center; gap:0.75rem;">
                <span class="material-symbols-outlined" style="color:var(--primary); font-size:1.25rem;">{f.icon}</span>
                <span style="font-family:'Manrope',sans-serif; font-size:0.8rem; color:var(--on-surface-variant); font-weight:600;">{f.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
      <!-- Product Highlights -->
      {product.highlights && product.highlights.length > 0 && (
        <div style="margin-top:3rem;">
          <h2 style="font-family:'Manrope',sans-serif; font-size:0.8rem; font-weight:800; letter-spacing:0.2em; text-transform:uppercase; color:var(--secondary); margin:0 0 1.25rem;">Why It Works</h2>
          <div class="highlights-grid">
            {product.highlights.map(h => (
              <div style="background:var(--surface-container-low); border-radius:1rem; padding:1.25rem; display:flex; flex-direction:column; gap:0.75rem;">
                <div style="width:2.5rem; height:2.5rem; background:linear-gradient(135deg,var(--primary),var(--secondary)); border-radius:0.75rem; display:flex; align-items:center; justify-content:center;">
                  <span class="material-symbols-outlined" style="font-size:1.25rem; color:#fff;">{h.icon}</span>
                </div>
                <div style="font-family:'Manrope',sans-serif; font-size:0.875rem; font-weight:700; color:var(--on-surface);">{h.title}</div>
                <div style="font-family:'Manrope',sans-serif; font-size:0.8rem; color:var(--on-surface-variant); line-height:1.6;">{h.description}</div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Ingredient / How It Works tabs -->
      {(product.composition || product.howItWorks || product.sideEffects) && (
        <div style="margin-top:3rem; border-top:1px solid var(--outline-variant); padding-top:2rem;">
          <!-- Tab buttons -->
          <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:1.5rem;">
            {product.howItWorks  && <button class="tab-btn active" data-tab="how"   style="padding:0.5rem 1.25rem; border-radius:9999px; font-family:'Manrope',sans-serif; font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; cursor:pointer; border:1.5px solid var(--primary); background:var(--primary); color:#fff; transition:all 0.2s;">How It Works</button>}
            {product.composition && <button class="tab-btn"        data-tab="comp"  style="padding:0.5rem 1.25rem; border-radius:9999px; font-family:'Manrope',sans-serif; font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; cursor:pointer; border:1.5px solid var(--outline-variant); background:transparent; color:var(--on-surface-variant); transition:all 0.2s;">Ingredients</button>}
            {product.sideEffects && <button class="tab-btn"        data-tab="side"  style="padding:0.5rem 1.25rem; border-radius:9999px; font-family:'Manrope',sans-serif; font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; cursor:pointer; border:1.5px solid var(--outline-variant); background:transparent; color:var(--on-surface-variant); transition:all 0.2s;">Safety Info</button>}
          </div>

          <!-- Tab panels -->
          {product.howItWorks  && <div class="tab-panel" data-panel="how"  style="display:block;"><p style="font-family:'Manrope',sans-serif; font-size:0.95rem; color:var(--on-surface-variant); line-height:1.8; margin:0;">{product.howItWorks}</p></div>}
          {product.composition && <div class="tab-panel" data-panel="comp" style="display:none;"><p style="font-family:'Manrope',sans-serif; font-size:0.875rem; color:var(--on-surface-variant); line-height:1.8; margin:0;">{product.composition}</p></div>}
          {product.sideEffects && <div class="tab-panel" data-panel="side" style="display:none;"><div style="display:flex; gap:0.75rem; background:rgba(201,150,12,0.08); border-radius:0.75rem; padding:1rem;"><span class="material-symbols-outlined" style="color:#c9960c; flex-shrink:0;">info</span><p style="font-family:'Manrope',sans-serif; font-size:0.875rem; color:var(--on-surface-variant); line-height:1.8; margin:0;">{product.sideEffects}</p></div></div>}
        </div>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .product-detail-grid { display:grid; grid-template-columns:1fr; gap:3rem; }
  @media (min-width:768px) { .product-detail-grid { grid-template-columns:1fr 1fr; } }

  .highlights-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
  @media (min-width:768px) { .highlights-grid { grid-template-columns: repeat(4,1fr); } }
  @media (max-width:400px) { .highlights-grid { grid-template-columns: 1fr; } }
</style>

<script>
  const WISHLIST_KEY = 'gladskin_wishlist';
  const CART_KEY     = 'gladskin_cart';

  function getWishlist() {
    try { return JSON.parse(localStorage.getItem(WISHLIST_KEY) || '[]'); } catch { return []; }
  }
  function getCart() {
    try { return JSON.parse(localStorage.getItem(CART_KEY) || '[]'); } catch { return []; }
  }

  function showToast(msg: string) {
    let t = document.getElementById('product-toast');
    if (!t) {
      t = document.createElement('div');
      t.id = 'product-toast';
      t.style.cssText = 'position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(4rem);background:var(--on-surface);color:var(--surface);padding:0.75rem 1.5rem;border-radius:9999px;font-family:Manrope,sans-serif;font-size:0.8rem;font-weight:600;opacity:0;transition:all 0.3s;z-index:100;white-space:nowrap;';
      document.body.appendChild(t);
    }
    t.textContent = msg;
    t.style.opacity = '1';
    t.style.transform = 'translateX(-50%) translateY(0)';
    setTimeout(() => { t!.style.opacity='0'; t!.style.transform='translateX(-50%) translateY(4rem)'; }, 2500);
  }

  // Qty controls
  let qty = 1;
  const display = document.getElementById('qty-display')!;
  document.getElementById('qty-minus')?.addEventListener('click', () => { if (qty > 1) { qty--; display.textContent = String(qty); } });
  document.getElementById('qty-plus')?.addEventListener('click', () => { qty++; display.textContent = String(qty); });

  // Add to cart
  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab!;
      document.querySelectorAll('.tab-btn').forEach(b => {
        const el = b as HTMLElement;
        const active = el.dataset.tab === tab;
        el.style.background  = active ? 'var(--primary)' : 'transparent';
        el.style.color       = active ? '#fff' : 'var(--on-surface-variant)';
        el.style.borderColor = active ? 'var(--primary)' : 'var(--outline-variant)';
      });
      document.querySelectorAll('.tab-panel').forEach(p => {
        (p as HTMLElement).style.display = (p as HTMLElement).dataset.panel === tab ? 'block' : 'none';
      });
    });
  });

  document.getElementById('add-to-cart')?.addEventListener('click', () => {
    const cart = getCart();
    const pid = document.getElementById('add-to-cart')!.dataset.productId!;
    const existing = cart.find((c: any) => c.id === pid);
    if (existing) { existing.quantity = (existing.quantity||1) + qty; }
    else {
      const btn = document.getElementById('add-to-wishlist')!;
      const data = JSON.parse(btn.dataset.product!);
      cart.push({ ...data, quantity: qty });
    }
    localStorage.setItem(CART_KEY, JSON.stringify(cart));
    const countEl = document.getElementById('cart-count');
    if (countEl) {
      const total = cart.reduce((s: number, c: any) => s + (c.quantity||1), 0);
      countEl.textContent = String(total);
    }
    showToast('Added to bag');
  });

  // Wishlist toggle
  const wishlistBtn   = document.getElementById('add-to-wishlist')!;
  const wishlistIcon  = document.getElementById('wishlist-icon')!;
  const wishlistLabel = document.getElementById('wishlist-label')!;
  const productData   = JSON.parse(wishlistBtn.dataset.product!);

  function syncWishlistBtn() {
    const saved = getWishlist().some((i: any) => i.id === productData.id);
    wishlistIcon.textContent  = saved ? 'favorite' : 'favorite_border';
    wishlistLabel.textContent = saved ? 'Saved to Wishlist' : 'Save to Wishlist';
    wishlistIcon.style.color  = saved ? 'var(--secondary)' : '';
    wishlistBtn.style.borderColor = saved ? 'var(--secondary)' : 'var(--primary)';
    wishlistBtn.style.color       = saved ? 'var(--secondary)' : 'var(--primary)';
    wishlistBtn.classList.toggle('saved', saved);
  }

  syncWishlistBtn();

  wishlistBtn.addEventListener('click', () => {
    const list = getWishlist();
    const idx  = list.findIndex((i: any) => i.id === productData.id);
    if (idx > -1) {
      list.splice(idx, 1);
      localStorage.setItem(WISHLIST_KEY, JSON.stringify(list));
      showToast('Removed from wishlist');
    } else {
      list.push(productData);
      localStorage.setItem(WISHLIST_KEY, JSON.stringify(list));
      showToast('Saved to wishlist ♥');
    }
    syncWishlistBtn();
  });
</script>
