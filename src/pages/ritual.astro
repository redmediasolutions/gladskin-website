---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const steps = [
  { step: '01', time: 'Morning', title: 'Cleanse & Prepare', description: 'Begin with our Botanical Micellar Water. Gently sweep across the face to lift impurities while preserving your skin\'s natural microbiome.' },
  { step: '02', time: 'Morning', title: 'Orchid Dew Serum', description: 'Apply 3–4 drops of Orchid Dew Serum to damp skin. Press gently into the skin allowing the bio-actives to penetrate deeply.' },
  { step: '03', time: 'Evening', title: 'Retinol Night Cream', description: 'As the skin enters its nocturnal repair phase, apply our Retinol Night Cream. Wake to visibly transformed, luminous skin.' },
];
---

<BaseLayout title="The Ritual | Gladskin">
  <Header />
  <main style="padding-top:3.25rem; min-height:100vh; background:var(--surface);">
    <div style="max-width:56rem; margin:0 auto; padding:1.5rem clamp(1.25rem,4vw,3rem) 2rem; text-align:center;">
      <span style="font-family:'Manrope',sans-serif; color:var(--secondary); letter-spacing:0.25em; text-transform:uppercase; font-size:0.85rem; font-weight:800; display:block; margin-bottom:0.75rem;">Guided Transformation</span>
      <h1 class="font-headline" style="font-size:clamp(2rem,3.5vw,2.75rem); color:var(--on-surface); margin:0 0 1rem; line-height:1.1;">The Orchid Ritual</h1>
      <p class="font-body" style="color:var(--on-surface-variant); font-size:1rem; line-height:1.8; max-width:36rem; margin:0 auto 2.5rem;">A carefully choreographed sequence of application designed to maximise bioavailability and sensory presence.</p>

      <div style="display:flex; flex-direction:column; gap:0; text-align:left;">
        {steps.map((s, i) => (
          <div style={`display:grid; gap:2rem; padding:3rem 0; border-top:1px solid var(--outline-variant); ${i === steps.length - 1 ? 'border-bottom:1px solid var(--outline-variant);' : ''}`} class="step-grid">
            <div style="display:flex; flex-direction:column; gap:0.5rem;">
              <span style="font-family:'Noto Serif',serif; font-size:3rem; color:var(--outline-variant); line-height:1; font-weight:300;">{s.step}</span>
              <span style="font-family:'Manrope',sans-serif; font-size:0.65rem; font-weight:800; text-transform:uppercase; letter-spacing:0.2em; color:var(--secondary);">{s.time}</span>
            </div>
            <div>
              <h3 class="font-headline" style="font-size:1.75rem; color:var(--on-surface); margin:0 0 1rem;">{s.title}</h3>
              <p class="font-body" style="color:var(--on-surface-variant); line-height:1.8; font-size:1.05rem; margin:0;">{s.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .step-grid { grid-template-columns: 6rem 1fr; align-items:start; }
  @media (max-width: 640px) { .step-grid { grid-template-columns: 1fr; } }
</style>
