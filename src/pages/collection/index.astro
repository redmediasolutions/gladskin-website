---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProductCard from '../../components/ProductCard.astro';
import CategoryNav from '../../components/CategoryNav.astro';

import {
  fetchProductsPaginated,
} from '../../lib/woocommerce';

const page = Number(
  Astro.url.searchParams.get(
    'page',
  ) || '1',
);

const {
  products,
  totalProducts,
  totalPages,
} =
  await fetchProductsPaginated({
    page,
    perPage: 24,
  });

---

<BaseLayout title="Collection | Gladskin">
  <Header />

  <main class="collection-main">

    <!-- Hero -->
    <div class="collection-hero">
      <div class="collection-hero-inner">
        <div>
          <p class="collection-eyebrow">
            All Products
          </p>

          <h1 class="collection-title font-headline">
            The Full Collection
          </h1>
        </div>

        <a
          href="/search"
          class="search-btn"
        >
          <span class="material-symbols-outlined">
            search
          </span>

          Search
        </a>
      </div>
    </div>

    <div class="collection-body">

      <!-- Categories -->
<CategoryNav selectedId={49} />

      <!-- Count -->
      <p class="result-count">
  {totalProducts} products
</p>

      <!-- Products -->
      <div class="products-grid">
        {products.map((product, i) => (
          <div
            class="product-item"
            style={`animation-delay:${Math.min(i * 40, 240)}ms`}
          >
            <ProductCard product={product} />
          </div>
        ))}
      </div>

      {
  totalPages > 1 && (
    <div class="pagination">
      {
        page > 1 && (
          <a
            href={`/collection?page=${page - 1}`}
            class="page-btn"
          >
            ← Previous
          </a>
        )
      }

      <div class="page-numbers">
        {Array.from(
          {
            length: totalPages,
          },
          (_, i) => i + 1,
        ).map((p) => (
          <a
            href={`/collection?page=${p}`}
            class={`page-number ${
              p === page
                ? 'active-page'
                : ''
            }`}
          >
            {p}
          </a>
        ))}
      </div>

      {
        page < totalPages && (
          <a
            href={`/collection?page=${page + 1}`}
            class="page-btn"
          >
            Next →
          </a>
        )
      }
    </div>
  )
}

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .collection-main {
    min-height: 100vh;
    background: var(--surface);
    padding-top: 3.25rem;
  }

  .collection-hero {
    background:
      linear-gradient(
        135deg,
        var(--surface-container-low) 0%,
        var(--surface) 100%
      );

    border-bottom: 1px solid var(--outline-variant);

    padding:
      2rem
      clamp(1.25rem, 4vw, 3rem)
      1.5rem;
  }

  .collection-hero-inner {
    max-width: 80rem;
    margin: 0 auto;

    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .collection-eyebrow {
    font-family: 'Manrope', sans-serif;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--secondary);
    margin: 0 0 0.35rem;
  }

  .collection-title {
    font-size: clamp(
      1.75rem,
      3vw,
      2.75rem
    );

    color: var(--on-surface);
    margin: 0;
    font-weight: 400;
  }

  .search-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;

    padding: 0.55rem 1.1rem;

    border: 1.5px solid var(--outline-variant);
    border-radius: 9999px;

    font-family: 'Manrope', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;

    color: var(--on-surface-variant);
    text-decoration: none;

    background: var(--surface-container-lowest);

    transition: all 0.2s;
  }

  .search-btn:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .search-btn .material-symbols-outlined {
    font-size: 1.05rem;
  }

  .collection-body {
    max-width: 80rem;
    margin: 0 auto;

    padding:
      1.5rem
      clamp(1.25rem, 4vw, 3rem)
      3rem;
  }

  /* PRIMARY CATEGORIES */

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;

    margin-bottom: 1rem;
  }

  .cat-filter {
    padding: 0.5rem 1rem;

    border-radius: 999px;

    border: 1px solid var(--outline-variant);

    text-decoration: none;

    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;

    text-transform: uppercase;
    letter-spacing: 0.08em;

    color: var(--on-surface-variant);

    transition: all 0.2s;
  }

  .cat-filter:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  /* SUB CATEGORIES */

  .sub-filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;

    margin-bottom: 1.5rem;
  }

  .sub-filter {
    padding: 0.4rem 0.9rem;

    border-radius: 999px;

    border: 1px solid var(--outline-variant);

    text-decoration: none;

    font-family: 'Manrope', sans-serif;
    font-size: 0.72rem;

    color: var(--on-surface-variant);

    transition: all 0.2s;
  }

  .sub-filter:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .result-count {
    font-family: 'Manrope', sans-serif;
    font-size: 0.8rem;
    color: var(--on-surface-variant);

    margin: 0 0 1.5rem;
  }

  /* CATEGORY NAV */

.category-nav {
  display: flex;
  align-items: flex-start;
  gap: 1.5rem;
  overflow-x: auto;
  padding-bottom: 0.75rem;
  margin-bottom: 1.5rem;

  scrollbar-width: none;
}

.category-nav::-webkit-scrollbar {
  display: none;
}

.category-item {
  flex-shrink: 0;

  display: flex;
  flex-direction: column;
  align-items: center;

  text-decoration: none;

  min-width: 72px;
}

.category-icon {
  width: 84px;
  height: 84px;

  border-radius: 50%;

  display: flex;
  align-items: center;
  justify-content: center;

  overflow: hidden;

  border: 3px solid #8f2a8d;

  background: #fff;

  transition: all 0.2s ease;
}

.category-icon img {
  width: 100%;
  height: 100%;

  object-fit: cover;
}

.category-item:hover .category-icon {
  transform: scale(1.05);
}

.category-name {
  margin-top: 0.65rem;

  font-family: 'Manrope', sans-serif;
  font-size: 0.9rem;
  font-weight: 600;

  color: var(--on-surface);

  text-align: center;
}

@media (max-width: 768px) {
  .category-nav {
    gap: 1.25rem;
  }

  .category-icon,
  .category-icon img {
    width: 64px;
    height: 64px;
  }

  .category-name {
    font-size: 0.85rem;
  }
}

  .products-grid {
    display: grid;

    grid-template-columns:
      repeat(2, 1fr);

    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .products-grid {
      grid-template-columns:
        repeat(3, 1fr);

      gap: 1.5rem;
    }
  }

  @media (min-width: 1280px) {
    .products-grid {
      grid-template-columns:
        repeat(4, 1fr);

      gap: 1.75rem;
    }
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .product-item {
    animation:
      fadeUp
      0.4s
      ease
      both;
  }

  .pagination {
  display: flex;
  align-items: center;
  justify-content: center;

  gap: 1rem;

  margin-top: 3rem;

  flex-wrap: wrap;
}

.page-btn,
.page-number {
  text-decoration: none;

  padding: 0.65rem 1rem;

  border-radius: 999px;

  border: 1px solid
    var(--outline-variant);

  color: var(--on-surface);

  font-family: 'Manrope',
    sans-serif;

  transition: all 0.2s ease;
}

.page-btn:hover,
.page-number:hover {
  border-color: var(--primary);
  color: var(--primary);
}

.page-numbers {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.active-page {
  background: var(--primary);
  color: white;
  border-color: var(--primary);
}
</style>