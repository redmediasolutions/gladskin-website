---
const navLinks = [
  { label: 'Atelier', href: '/', active: true },
  { label: 'Collection', href: '/collection' },
  { label: 'Ritual', href: '/ritual' },
];
---

<header
  id="main-header"
  class="fixed top-0 w-full z-50 transition-all duration-300"
  style="background: rgba(252,249,249,0.7); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px); padding: 1.5rem 3rem;"
>
  <div style="display:flex; align-items:center; justify-content:space-between; width:100%; max-width:80rem; margin:0 auto;">
    <!-- Left Nav -->
    <nav style="display:none;" class="desktop-nav" aria-label="Primary">
      {navLinks.map(link => (
        <a
          href={link.href}
          style={`margin-right:2.5rem; font-family:'Manrope',sans-serif; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; font-weight:600; text-decoration:none; transition:color 0.3s; color:${link.active ? 'var(--primary)' : 'var(--on-surface-variant)'}; ${link.active ? 'border-bottom:2px solid var(--primary); padding-bottom:4px;' : ''}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Logo -->
    <div style="font-family:'Noto Serif',serif; font-size:1.5rem; font-weight:300; letter-spacing:0.3em; color:var(--primary); text-transform:uppercase; text-align:center; flex:1;">
      Gladskin
    </div>

    <!-- Right Actions -->
    <div style="display:flex; align-items:center; gap:1.5rem;">
      <a href="/profile" style="display:none; font-family:'Manrope',sans-serif; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; font-weight:600; color:var(--on-surface-variant); text-decoration:none;" class="desktop-link">
        Profile
      </a>
      <a href="/cart" style="position:relative;" aria-label="Shopping bag">
        <span class="material-symbols-outlined" style="color:var(--primary); font-size:1.5rem;">shopping_bag</span>
        <span id="cart-count" style="position:absolute; top:-4px; right:-4px; background:var(--secondary); color:white; font-size:10px; width:16px; height:16px; border-radius:9999px; display:flex; align-items:center; justify-content:center;">0</span>
      </a>
      <button id="mobile-menu-btn" aria-label="Open menu" style="background:none; border:none; cursor:pointer; display:block;" class="mobile-only">
        <span class="material-symbols-outlined" style="color:var(--primary); font-size:1.5rem;">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" style="display:none; flex-direction:column; gap:1rem; padding:1.5rem 0 0.5rem; border-top:1px solid var(--outline-variant); margin-top:1rem;">
    {navLinks.map(link => (
      <a href={link.href} style="font-family:'Manrope',sans-serif; font-size:0.875rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--on-surface); text-decoration:none; font-weight:600;">
        {link.label}
      </a>
    ))}
    <a href="/profile" style="font-family:'Manrope',sans-serif; font-size:0.875rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--on-surface); text-decoration:none; font-weight:600;">Profile</a>
  </div>
</header>

<style>
  @media (min-width: 768px) {
    .desktop-nav { display: flex !important; }
    .desktop-link { display: block !important; }
    .mobile-only { display: none !important; }
  }
</style>

<script>
  // Header scroll effect
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header!.style.padding = '0.75rem 3rem';
      header!.style.boxShadow = '0 1px 12px rgba(0,0,0,0.06)';
      header!.style.background = 'rgba(252,249,249,0.95)';
    } else {
      header!.style.padding = '1.5rem 3rem';
      header!.style.boxShadow = 'none';
      header!.style.background = 'rgba(252,249,249,0.7)';
    }
  });

  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isOpen = menu!.style.display === 'flex';
    menu!.style.display = isOpen ? 'none' : 'flex';
  });
</script>
