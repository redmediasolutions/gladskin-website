---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import { getProductsByCategory } from '../data/products.ts';
import { HOMEPAGE_CATEGORY_ID, RECOMMENDED_CATEGORY_ID } from '../lib/woocommerce.ts';

const homepageProducts = await getProductsByCategory(HOMEPAGE_CATEGORY_ID);
const recommendedProducts = await getProductsByCategory(RECOMMENDED_CATEGORY_ID);
---

<BaseLayout>
  <Header />

  <main>
    <!-- Hero — full viewport height, image fills right column -->
    <section class="hero-section" style="background:var(--surface); overflow:hidden;">
      <div class="hero-grid">

        <!-- Left: text -->
        <div class="hero-text">
          <h1 class="font-headline" style="font-size:clamp(2.25rem,4.5vw,4rem); color:var(--on-surface); line-height:1.05; letter-spacing:-0.02em; margin:0 0 1.25rem;">
            Bloom into<br/><span style="color:var(--primary);">Your</span><br/>Best Skin
          </h1>
          <p style="font-family:'Manrope',sans-serif; font-size:clamp(0.875rem,1.2vw,1rem); color:var(--on-surface-variant); line-height:1.75; margin:0 0 2rem; max-width:24rem;">
            Science-backed solutions for eczema-prone skin.
            Restoring balance, one drop at a time.
          </p>
          <div>
            <a href="/collection"
              style="display:inline-block; padding:0.9rem 1.875rem; background:#8C2F67; color:#fff; border-radius:0.875rem; font-family:'Manrope',sans-serif; font-weight:600; font-size:0.75rem; letter-spacing:0.12em; text-transform:uppercase; text-decoration:none; transition:background 0.2s, transform 0.2s;"
              onmouseover="this.style.background='#6F0562';this.style.transform='translateY(-2px)'"
              onmouseout="this.style.background='#8C2F67';this.style.transform=''">
              EXPLORE COLLECTION
            </a>
          </div>
        </div>

        <!-- Right: image fills column height -->
        <div class="hero-image">
          <img
            src="https://store.gladskin.in/wp-content/uploads/2026/06/WhatsApp-Image-2026-06-20-at-13.40.36.jpeg"
            alt="Gladskin skincare"
            loading="eager"
          />
        </div>

      </div>
    </section>

    <!-- Homepage Picks -->
    {homepageProducts.length > 0 && (
      <section style="padding:clamp(3rem,8vw,8rem) 0; background:var(--surface-container-low);">
        <div style="max-width:80rem; margin:0 auto; padding:0 clamp(1.25rem,4vw,3rem);">
          <div class="collection-header" style="display:flex; flex-direction:column; gap:1.5rem; margin-bottom:4rem;">
            <div>
              <span style="font-family:'Manrope',sans-serif; color:var(--secondary); letter-spacing:0.3em; text-transform:uppercase; font-size:0.7rem; font-weight:800; display:block; margin-bottom:1rem;">The Curated Selection</span>
              <h2 class="font-headline" style="font-size:clamp(2rem,4vw,3rem); color:var(--on-surface); margin:0;">Seasonal Icons</h2>
            </div>
            <a href="/collection" style="font-family:'Manrope',sans-serif; color:var(--primary); font-weight:700; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; text-decoration:none; display:flex; align-items:center; gap:0.5rem;" onmouseover="this.style.color='var(--secondary)'" onmouseout="this.style.color='var(--primary)'">
              View All <span class="material-symbols-outlined" style="font-size:1.125rem;">arrow_forward</span>
            </a>
          </div>
          <div class="products-grid">
            {homepageProducts.map((product, i) => (
              <ProductCard product={product} delay={i * 200} />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Recommended For You -->
    {recommendedProducts.length > 0 && (
      <section style="padding:clamp(3rem,8vw,8rem) 0; background:var(--surface);">
        <div style="max-width:80rem; margin:0 auto; padding:0 clamp(1.25rem,4vw,3rem);">
          <div class="collection-header" style="display:flex; flex-direction:column; gap:1.5rem; margin-bottom:4rem;">
            <div>
              <span style="font-family:'Manrope',sans-serif; color:var(--secondary); letter-spacing:0.3em; text-transform:uppercase; font-size:0.7rem; font-weight:800; display:block; margin-bottom:1rem;">Just For You</span>
              <h2 class="font-headline" style="font-size:clamp(2rem,4vw,3rem); color:var(--on-surface); margin:0;">Recommended</h2>
            </div>
            <a href="/collection" style="font-family:'Manrope',sans-serif; color:var(--primary); font-weight:700; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; text-decoration:none; display:flex; align-items:center; gap:0.5rem;" onmouseover="this.style.color='var(--secondary)'" onmouseout="this.style.color='var(--primary)'">
              View All <span class="material-symbols-outlined" style="font-size:1.125rem;">arrow_forward</span>
            </a>
          </div>
          <div class="products-grid">
            {recommendedProducts.map((product, i) => (
              <ProductCard product={product} delay={i * 200} />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Download App -->
<section class="app-section">
  <div class="app-inner">

    <div class="app-content">
      <span class="app-eyebrow">
        Gladskin Mobile App
      </span>

      <h2 class="font-headline app-title">
        Download the Gladskin App
      </h2>

      <p class="app-body">
        Get up to <strong>20% OFF on your first order.</strong>
        Exclusive app-only offers, faster checkout,
        order tracking, and early access to new products.
      </p>

      <div class="app-actions">
        <a
          href="https://onelink.to/ee6h6p"
          class="app-btn"
        >
          Download App
        </a>
      </div>
    </div>

    <div class="app-qr">
      <div class="qr-card">
        <img
          src="/download-qr-gladskin.jpg"
          alt="Download Gladskin App"
        />

        <span>
          Scan to download
        </span>
      </div>
    </div>

  </div>
</section>

    <!-- Why Gladskin -->
    <section class="why-section">
      <div class="why-inner">
        <div class="why-header">
          <span class="why-eyebrow">Why Gladskin</span>
          <h2 class="font-headline why-title">Skincare that actually works.</h2>
        </div>
        <div class="why-pillars">
          {[
            { icon: 'science',        title: 'Dermat Tested',     body: 'Every formula is clinically validated for safety and efficacy before it reaches your skin.' },
            { icon: 'eco',            title: 'Natural Actives',   body: 'Plant-derived ingredients chosen for proven results — no fillers, no compromise.' },
            { icon: 'price_check',    title: 'Honest Pricing',    body: 'Premium skincare at prices that make daily care sustainable for everyone.' },
            { icon: 'diversity_3',    title: 'All Skin Types',    body: 'Formulated to work across skin tones, types, and concerns — inclusive by design.' },
          ].map(p => (
            <div class="why-pillar">
              <div class="why-icon">
                <span class="material-symbols-outlined">{p.icon}</span>
              </div>
              <div class="why-pillar-title">{p.title}</div>
              <p class="why-pillar-body">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- The Ritual -->
    <section class="ritual-section">
      <div class="ritual-inner">
        <div class="ritual-text">
          <span class="why-eyebrow">Your Daily Ritual</span>
          <h2 class="font-headline ritual-title">A routine worth keeping.</h2>
          <p class="ritual-body">Simple, consistent steps that deliver visible results. Gladskin's skincare ritual is designed to fit into your day — morning or night — without overwhelm.</p>
        </div>
        <div class="ritual-steps">
          {[
            { step: '01', label: 'Cleanse',   desc: 'Start with a clean canvas.' },
            { step: '02', label: 'Treat',     desc: 'Active ingredients, targeted results.' },
            { step: '03', label: 'Moisturise',desc: 'Lock in hydration, protect the barrier.' },
          ].map(s => (
            <div class="ritual-step">
              <span class="ritual-step-num">{s.step}</span>
              <div>
                <div class="ritual-step-label">{s.label}</div>
                <div class="ritual-step-desc">{s.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
   /* ── Hero ── */
  .hero-section {
    height: calc(100vh - 3.25rem);
    min-height: 480px;
    max-height: 900px;
    box-sizing: border-box; /* Ensures padding doesn't break the height */
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    height: 100%;
  }
  .hero-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem clamp(1.25rem, 5vw, 4rem);
    order: 1;
  }
  .hero-image {
    order: 0;
    overflow: hidden;
    min-height: 280px;
    background: #2a2830;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0 0 1.5rem 1.5rem;
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    /* CHANGED: 'cover' fills the space perfectly and removes the dark bar */
    object-fit: cover; 
    display: block;
  }

  @media (min-width: 768px) {
    .hero-grid  { 
      grid-template-columns: 1fr 1fr; 
    }
    .hero-section { 
      /* ADDED: Top, right, and bottom padding to beautifully frame the image */
      padding: 2rem 2rem 2rem 0; 
    }
    .hero-text  { 
      order: 0; 
      padding: 0 clamp(2rem, 5vw, 5rem); 
    }
    .hero-image { 
      order: 1; 
      border-radius: 1.5rem; 
    }
  }

  /* Slide-in animations */
  @keyframes slideLeft {
    from { opacity: 0; transform: translateX(-48px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes slideRight {
    from { opacity: 0; transform: translateX(48px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  .hero-text  { animation: slideLeft  0.85s cubic-bezier(0.22,1,0.36,1) both; }
  .hero-image { animation: slideRight 0.85s cubic-bezier(0.22,1,0.36,1) 0.15s both; }
  /* ── Products grid ── */
  .products-grid { display:grid; grid-template-columns:1fr; gap:1.5rem; }
  @media (min-width: 768px) {
    .collection-header { flex-direction:row !important; align-items:flex-end !important; justify-content:space-between !important; }
    .products-grid { grid-template-columns: repeat(3,1fr); }
  }

  /* ── Why Gladskin ── */
  .why-section {
    background: var(--surface);
    padding: 3rem 0;
    border-top: 1px solid var(--outline-variant);
  }
  .why-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem,4vw,3rem);
  }
  .why-header {
    margin-bottom: 2rem;
  }
  .why-eyebrow {
    font-family: 'Manrope', sans-serif;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--primary);
    display: block;
    margin-bottom: 0.4rem;
  }
  .why-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--on-surface);
    margin: 0;
    font-weight: 400;
  }
  .why-pillars {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 768px) {
    .why-pillars { grid-template-columns: repeat(4, 1fr); }
  }
  .why-pillar {
    background: var(--surface-container-lowest);
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .why-icon {
    width: 2.25rem;
    height: 2.25rem;
    background: linear-gradient(135deg, rgba(111,5,98,0.1), rgba(111,5,98,0.05));
    border-radius: 0.625rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.25rem;
  }
  .why-icon .material-symbols-outlined { font-size: 1.1rem; color: var(--primary); }
  .why-pillar-title {
    font-family: 'Manrope', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--on-surface);
  }
  .why-pillar-body {
    font-family: 'Manrope', sans-serif;
    font-size: 0.76rem;
    color: var(--on-surface-variant);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Ritual ── */
  .ritual-section {
    background: linear-gradient(135deg, #3a0035 0%, #6f0562 60%, #8c2f67 100%);
    padding: 3rem 0;
  }
  .ritual-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem,4vw,3rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .ritual-inner { grid-template-columns: 1fr 1fr; gap: 4rem; }
  }
  .ritual-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: #fff;
    margin: 0.4rem 0 0.875rem;
    font-weight: 400;
  }
  .ritual-body {
    font-family: 'Manrope', sans-serif;
    font-size: 0.88rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.75;
    margin: 0 0 1.5rem;
  }
  .ritual-section .why-eyebrow { color: rgba(255,172,231,0.9); }
  .ritual-cta {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    background: rgba(255,255,255,0.15);
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.35);
    border-radius: 9999px;
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
    backdrop-filter: blur(8px);
  }
  .ritual-cta:hover { background: rgba(255,255,255,0.25); border-color: rgba(255,255,255,0.6); }
  .ritual-steps {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .ritual-step {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 0.875rem;
    padding: 1rem 1.25rem;
    backdrop-filter: blur(8px);
  }
  .ritual-step-num {
    font-family: 'Noto Serif', serif;
    font-size: 1.25rem;
    color: rgba(255,172,231,0.8);
    font-weight: 400;
    flex-shrink: 0;
    min-width: 2rem;
  }
  .ritual-step-label {
    font-family: 'Manrope', sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.15rem;
  }
  .ritual-step-desc {
    font-family: 'Manrope', sans-serif;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.6);
  }

  /* ─────────────────────────────
   APP DOWNLOAD
───────────────────────────── */

.app-section {
  padding: 3rem 0;

  background:
    radial-gradient(
      circle at top right,
      rgba(255,255,255,.12),
      transparent 30%
    ),
    linear-gradient(
      135deg,
      #4b003d 0%,
      #6f0562 45%,
      #8c2f67 100%
    );

  position: relative;

  overflow: hidden;
}

.app-inner {
  max-width: 80rem;

  min-height: auto;

  margin: 0 auto;

  padding:
    0
    clamp(
      1.5rem,
      4vw,
      3rem
    );

  display: grid;

  grid-template-columns:
    1.5fr
    0.9fr;

  gap: 2rem;

  align-items: center;
}
.app-eyebrow {
  display: block;

  font-family: 'Manrope',
    sans-serif;

  font-size: 0.7rem;

  font-weight: 800;

  letter-spacing: 0.3em;

  text-transform: uppercase;

  color: rgba(
    255,
    255,
    255,
    0.75
  );

  margin-bottom: 1rem;
}

.app-title {
  color: white;

  margin: 0 0 1rem;

  line-height: 1.05;

  font-size:
    clamp(
      1.6rem,
      3vw,
      2.25rem
    );
}

.app-body {
  font-family: 'Manrope',
    sans-serif;

  color:
    rgba(
      255,
      255,
      255,
      .82
    );

  font-size: 0.95rem;

  line-height: 1.6;

  max-width: 40rem;
}

.app-body strong {
  color: white;
}

.app-actions {
  margin-top: 1.25rem;
}

.app-btn {
  display: inline-flex;

  align-items: center;
  justify-content: center;

  padding:
    0.75rem
    1.75rem;

  background: white;

  color: var(--primary);

  text-decoration: none;

  border-radius: 999px;

  font-family: 'Manrope',
    sans-serif;

  font-size: .8rem;

  font-weight: 800;

  letter-spacing: .08em;

  text-transform: uppercase;

  transition: all .25s ease;
}
.app-btn:hover {
  transform: translateY(-2px);

  box-shadow:
    0 12px 24px
    rgba(
      0,
      0,
      0,
      0.18
    );
}

.app-qr {
  display: flex;
  justify-content: center;
}

.qr-card {
  background: white;
  border-radius: 1.5rem;
  padding: 1rem;
  width: 160px;
  text-align: center;
  box-shadow: 0 12px 32px rgba(0, 0, 0, .22);
}

.qr-card img {
  width: 100%;
  display: block;
  border-radius: 0.75rem;
}

.qr-card span {
  display: block;
  margin-top: 0.75rem;
  font-family: 'Manrope', sans-serif;
  font-size: .78rem;
  font-weight: 700;
  color: var(--primary);
}

/* Mobile: single column, centred */
@media (max-width: 767px) {
  .app-inner {
    grid-template-columns: 1fr;
    gap: 1.5rem;
    text-align: center;
  }
  .app-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .app-body {
    max-width: 26rem;
  }
  .qr-card {
    width: 140px;
  }
}

@media (min-width: 1024px) {
  .app-inner {
    grid-template-columns: 1.5fr 0.8fr;
  }
  .qr-card {
    width: 220px;
  }
}
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('active'); }),
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );
  document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
</script>
