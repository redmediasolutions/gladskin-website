---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Checkout | Gladskin">
  <Header />
  <main style="padding-top:3.25rem; min-height:100vh; background:var(--surface);">
    <div style="max-width:72rem; margin:0 auto; padding:1.5rem clamp(1.25rem,4vw,3rem) 3rem;">

      <h1 class="font-headline" style="font-size:clamp(1.75rem,3vw,2.5rem); color:var(--on-surface); margin:0 0 2rem;">Checkout</h1>

      <!-- Empty cart guard -->
      <div id="empty-guard" style="display:none; text-align:center; padding:5rem 0;">
        <span class="material-symbols-outlined" style="font-size:4rem; color:var(--outline-variant); display:block; margin-bottom:1rem;">shopping_bag</span>
        <p style="font-family:'Manrope',sans-serif; color:var(--on-surface-variant); margin:0 0 1.5rem;">Your bag is empty.</p>
        <a href="/collection" style="display:inline-block; padding:1rem 2.5rem; background:var(--primary); color:#fff; border-radius:9999px; font-family:'Manrope',sans-serif; font-weight:700; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; text-decoration:none;">Explore Collection</a>
      </div>

      <div id="checkout-layout" class="checkout-layout">

        <!-- LEFT: Delivery Address -->
        <div style="display:flex; flex-direction:column; gap:1.5rem;">

          <!-- Saved addresses -->
          <div style="background:var(--surface-container-lowest); border:1px solid var(--outline-variant); border-radius:1rem; padding:1.5rem;">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1rem;">
              <h2 style="font-family:'Manrope',sans-serif; font-size:0.8rem; font-weight:800; letter-spacing:0.15em; text-transform:uppercase; color:var(--on-surface); margin:0;">Delivery Address</h2>
              <button id="add-addr-toggle" type="button" style="display:flex; align-items:center; gap:0.3rem; padding:0.5rem 1rem; background:none; border:1px solid var(--outline-variant); border-radius:9999px; font-family:'Manrope',sans-serif; font-size:0.7rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--primary); cursor:pointer;">
                <span class="material-symbols-outlined" style="font-size:0.95rem;">add</span> New Address
              </button>
            </div>
            <div id="saved-addresses" style="display:flex; flex-direction:column; gap:0.75rem;"></div>
            <p id="no-addr-msg" style="display:none; font-family:'Manrope',sans-serif; font-size:0.85rem; color:var(--on-surface-variant); margin:0;">No saved addresses yet. Add one to continue.</p>

            <!-- New address form -->
            <form id="address-form" style="display:none; gap:1rem; margin-top:1.25rem; border-top:1px solid var(--outline-variant); padding-top:1.25rem;">
              <div class="form-row-2">
                <div class="field-group">
                  <label class="field-label">Full Name *</label>
                  <input id="f-name" type="text" placeholder="Elena Rossi" required class="field-input" />
                </div>
                <div class="field-group">
                  <label class="field-label">Phone Number *</label>
                  <input id="f-phone" type="tel" placeholder="10-digit number" required maxlength="10" class="field-input" />
                </div>
              </div>
              <div class="field-group">
                <label class="field-label">House / Street / Area *</label>
                <input id="f-address" type="text" placeholder="123, Orchid Lane, Botanical Heights" required class="field-input" />
              </div>
              <div class="form-row-3">
                <div class="field-group">
                  <label class="field-label">City *</label>
                  <input id="f-city" type="text" placeholder="Mumbai" required class="field-input" />
                </div>
                <div class="field-group">
                  <label class="field-label">State *</label>
                  <input id="f-state" type="text" placeholder="Maharashtra" required class="field-input" />
                </div>
                <div class="field-group">
                  <label class="field-label">Pincode *</label>
                  <input id="f-pincode" type="text" placeholder="400001" required maxlength="6" class="field-input" />
                </div>
              </div>
              <div style="display:flex; gap:0.75rem; justify-content:flex-end;">
                <button id="cancel-addr-form" type="button" style="padding:0.7rem 1.25rem; background:none; border:1.5px solid var(--outline-variant); border-radius:9999px; font-family:'Manrope',sans-serif; font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; cursor:pointer; color:var(--on-surface-variant);">Cancel</button>
                <button id="save-new-addr" type="button" style="padding:0.7rem 1.5rem; background:var(--primary); border:none; border-radius:9999px; font-family:'Manrope',sans-serif; font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; cursor:pointer; color:#fff;">Save &amp; Use This Address</button>
              </div>
            </form>
          </div>

          <!-- Payment method -->
          <div style="background:var(--surface-container-lowest); border:1px solid var(--outline-variant); border-radius:1rem; padding:1.5rem;">
            <h2 style="font-family:'Manrope',sans-serif; font-size:0.8rem; font-weight:800; letter-spacing:0.15em; text-transform:uppercase; color:var(--on-surface); margin:0 0 1rem;">Payment Method</h2>
            <div style="display:flex; flex-direction:column; gap:0.75rem;">
              <div data-pm="cod" class="pm-option" style="display:flex; align-items:center; gap:0.75rem; border:2px solid var(--primary); background:var(--surface-container); border-radius:0.75rem; padding:1rem; cursor:pointer;">
                <span class="material-symbols-outlined" style="color:var(--primary); font-size:1.5rem;">payments</span>
                <div>
                  <div style="font-family:'Manrope',sans-serif; font-weight:700; font-size:0.9rem; color:var(--on-surface);">Cash on Delivery</div>
                  <div class="pm-sub" style="font-family:'Manrope',sans-serif; font-size:0.75rem; color:var(--on-surface-variant);">Pay when your order arrives</div>
                </div>
                <span class="material-symbols-outlined pm-check" style="color:var(--primary); margin-left:auto; font-size:1.25rem; font-variation-settings:'FILL' 1">radio_button_checked</span>
              </div>
              <div data-pm="online" class="pm-option" style="display:flex; align-items:center; gap:0.75rem; border:2px solid var(--outline-variant); background:transparent; border-radius:0.75rem; padding:1rem; cursor:pointer;">
                <span class="material-symbols-outlined" style="color:var(--on-surface-variant); font-size:1.5rem;">credit_card</span>
                <div>
                  <div style="font-family:'Manrope',sans-serif; font-weight:700; font-size:0.9rem; color:var(--on-surface);">Pay Online</div>
                  <div class="pm-sub" style="font-family:'Manrope',sans-serif; font-size:0.75rem; color:var(--on-surface-variant);">UPI, Cards, Netbanking via Razorpay</div>
                </div>
                <span class="material-symbols-outlined pm-check" style="color:var(--on-surface-variant); margin-left:auto; font-size:1.25rem;">radio_button_unchecked</span>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT: Order Summary -->
        <div style="display:flex; flex-direction:column; gap:1rem;">
          <div style="background:var(--surface-container-low); border-radius:1rem; padding:1.5rem; position:sticky; top:4rem;">
            <h2 style="font-family:'Manrope',sans-serif; font-size:0.8rem; font-weight:800; letter-spacing:0.15em; text-transform:uppercase; color:var(--on-surface); margin:0 0 1.25rem;">Order Summary</h2>

            <!-- Items -->
            <div id="order-items" style="display:flex; flex-direction:column; gap:0.75rem; margin-bottom:1.25rem; max-height:16rem; overflow-y:auto;"></div>

            <!-- Totals -->
            <div style="border-top:1px solid var(--outline-variant); padding-top:1rem; display:flex; flex-direction:column; gap:0.6rem; margin-bottom:1.25rem;">
              <div style="display:flex; justify-content:space-between; font-family:'Manrope',sans-serif; font-size:0.875rem; color:var(--on-surface-variant);">
                <span>Subtotal</span><span id="co-subtotal">₹0</span>
              </div>
              <div style="display:flex; justify-content:space-between; font-family:'Manrope',sans-serif; font-size:0.875rem; color:var(--on-surface-variant);">
                <span>Shipping</span>
                <span id="co-shipping" style="font-weight:600;"></span>
              </div>
              <div style="display:flex; justify-content:space-between; font-family:'Manrope',sans-serif; font-size:0.875rem; color:var(--on-surface-variant);">
                <span>Tax</span><span id="co-tax">₹0</span>
              </div>
              <div id="co-codcharge-row" style="display:none; justify-content:space-between; font-family:'Manrope',sans-serif; font-size:0.875rem; color:var(--on-surface-variant);">
                <span>COD Charge</span><span id="co-codcharge">₹0</span>
              </div>
              <div id="free-shipping-bar" style="background:var(--surface-container); border-radius:9999px; overflow:hidden; height:4px; display:none;">
                <div id="shipping-progress" style="height:100%; background:linear-gradient(90deg,var(--primary),var(--secondary)); transition:width 0.4s;"></div>
              </div>
              <p id="shipping-tip" style="font-family:'Manrope',sans-serif; font-size:0.72rem; color:var(--secondary); margin:0; display:none;"></p>
            </div>
            <div style="display:flex; justify-content:space-between; font-family:'Noto Serif',serif; font-size:1.15rem; color:var(--on-surface); font-weight:400; margin-bottom:1.5rem; border-top:1px solid var(--outline-variant); padding-top:1rem;">
              <span>Total</span><span id="co-total">₹0</span>
            </div>

            <button id="place-order-btn" style="width:100%; padding:1.1rem; background:linear-gradient(135deg,var(--primary),var(--primary-container)); color:#fff; border:none; border-radius:9999px; font-family:'Manrope',sans-serif; font-weight:700; font-size:0.8rem; letter-spacing:0.2em; text-transform:uppercase; cursor:pointer; transition:opacity 0.2s; display:flex; align-items:center; justify-content:center; gap:0.5rem;">
              <span class="material-symbols-outlined" style="font-size:1.1rem;">check_circle</span>
              Place Order
            </button>
            <p style="font-family:'Manrope',sans-serif; font-size:0.72rem; color:var(--on-surface-variant); text-align:center; margin:0.75rem 0 0;">
              By placing your order you agree to our <a href="/terms" style="color:var(--primary); text-decoration:none;">Terms of Service</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .checkout-layout { display:flex; flex-direction:column; gap:1.5rem; }
  .form-row-2 { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
  .form-row-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:1rem; }
  .field-group { display:flex; flex-direction:column; gap:0.4rem; }
  .field-label { font-family:'Manrope',sans-serif; font-size:0.72rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--on-surface-variant); }
  .field-input { padding:0.7rem 1rem; border:1px solid var(--outline-variant); border-radius:0.625rem; font-family:'Manrope',sans-serif; font-size:0.9rem; color:var(--on-surface); background:var(--surface); outline:none; transition:border-color 0.2s; width:100%; box-sizing:border-box; }
  .field-input:focus { border-color:var(--primary); }
  @media (min-width:768px) {
    .checkout-layout { display:grid !important; grid-template-columns:1fr 22rem; gap:2rem; }
  }
  @media (max-width:639px) {
    .form-row-2, .form-row-3 { grid-template-columns:1fr !important; }
  }
</style>

<script>
  import { subscribeToAuth } from '../lib/auth';
  import {
    subscribeToCart, listAddresses, addAddress,
    type CartItemDoc, type AddressDoc, type AddressInput,
  } from '../lib/firestore-data';
  import {
    getCartRates, createSecureOrder, finalizeOrder,
    loadRazorpayScript, openRazorpayCheckout,
    type BillingShipping, type CartRates,
  } from '../lib/checkout';

  let uid: string | null = null;
  let cartItems: Array<CartItemDoc & { id: string }> = [];
  let addresses: AddressDoc[] = [];
  let selectedAddrId: string | null = null;
  let paymentMethod: 'cod' | 'online' = 'cod';
  let rates: CartRates | null = null;
  let placingOrder = false;
  let unsubscribeCart: (() => void) | null = null;

  const placeBtn   = document.getElementById('place-order-btn') as HTMLButtonElement;
  const addrList   = document.getElementById('saved-addresses')!;
  const noAddrMsg  = document.getElementById('no-addr-msg')!;
  const addrForm   = document.getElementById('address-form') as HTMLFormElement;
  const addToggle  = document.getElementById('add-addr-toggle')!;
  const cancelForm = document.getElementById('cancel-addr-form')!;

  function showToast(msg: string, err = false) {
    let t = document.getElementById('checkout-toast');
    if (!t) {
      t = document.createElement('div');
      t.id = 'checkout-toast';
      t.style.cssText = 'position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(4rem);padding:0.75rem 1.5rem;border-radius:9999px;font-family:Manrope,sans-serif;font-size:0.8rem;font-weight:600;opacity:0;transition:all 0.3s;z-index:300;white-space:nowrap;';
      document.body.appendChild(t);
    }
    t.style.background = err ? '#c62828' : 'var(--on-surface)';
    t.style.color = '#fff';
    t.textContent = msg;
    t.style.opacity = '1';
    t.style.transform = 'translateX(-50%) translateY(0)';
    setTimeout(() => { t!.style.opacity='0'; t!.style.transform='translateX(-50%) translateY(4rem)'; }, 3000);
  }

  // ── Address list / form ──────────────────────────────────────────────
  function renderAddresses() {
    if (addresses.length === 0) {
      noAddrMsg.style.display = 'block';
      addrList.innerHTML = '';
      return;
    }
    noAddrMsg.style.display = 'none';
    if (!selectedAddrId || !addresses.find(a => a.id === selectedAddrId)) selectedAddrId = addresses[0].id;

    addrList.innerHTML = addresses.map(a => `
      <div onclick="window.__selectAddr('${a.id}')" id="addr-${a.id}"
        style="border:2px solid ${a.id===selectedAddrId ? 'var(--primary)' : 'var(--outline-variant)'}; border-radius:0.75rem; padding:0.875rem 1rem; cursor:pointer; transition:border-color 0.2s; background:var(--surface-container-lowest);">
        <div style="display:flex; justify-content:space-between; align-items:flex-start;">
          <div>
            <div style="font-family:'Manrope',sans-serif; font-weight:700; font-size:0.875rem; color:var(--on-surface);">${a.name}</div>
            <div style="font-family:'Manrope',sans-serif; font-size:0.8rem; color:var(--on-surface-variant); margin-top:0.2rem;">${a.address}, ${a.city}, ${a.state} – ${a.pincode}</div>
            <div style="font-family:'Manrope',sans-serif; font-size:0.8rem; color:var(--on-surface-variant);">📞 ${a.phone}</div>
          </div>
          ${a.id === selectedAddrId ? `<span class="material-symbols-outlined" style="color:var(--primary); font-variation-settings:'FILL' 1">check_circle</span>` : ''}
        </div>
      </div>
    `).join('');
  }

  (window as any).__selectAddr = (id: string) => { selectedAddrId = id; renderAddresses(); };

  function openAddrForm() {
    addrForm.style.display = 'grid';
    addToggle.style.display = 'none';
  }
  function closeAddrForm() {
    addrForm.style.display = 'none';
    addToggle.style.display = 'flex';
    addrForm.reset();
  }
  addToggle.addEventListener('click', openAddrForm);
  cancelForm.addEventListener('click', closeAddrForm);

  document.getElementById('save-new-addr')!.addEventListener('click', async () => {
    if (!uid) return;
    const name    = (document.getElementById('f-name')    as HTMLInputElement).value.trim();
    const phone   = (document.getElementById('f-phone')   as HTMLInputElement).value.trim();
    const address = (document.getElementById('f-address') as HTMLInputElement).value.trim();
    const city    = (document.getElementById('f-city')    as HTMLInputElement).value.trim();
    const state   = (document.getElementById('f-state')   as HTMLInputElement).value.trim();
    const pincode = (document.getElementById('f-pincode') as HTMLInputElement).value.trim();

    if (!name || !phone || !address || !city || !state || !pincode) { showToast('Please fill in all address fields.', true); return; }
    if (!/^\d{10}$/.test(phone))  { showToast('Enter a valid 10-digit phone number.', true); return; }
    if (!/^\d{6}$/.test(pincode)) { showToast('Enter a valid 6-digit pincode.', true); return; }

    const data: AddressInput = { name, phone, address, city, state, pincode };
    try {
      const ref = await addAddress(uid, data);
      addresses = await listAddresses(uid);
      selectedAddrId = ref.id;
      renderAddresses();
      closeAddrForm();
      showToast('Address saved');
    } catch {
      showToast('Could not save address. Try again.', true);
    }
  });

  // ── Payment method ───────────────────────────────────────────────────
  document.querySelectorAll('.pm-option').forEach(el => {
    el.addEventListener('click', () => {
      paymentMethod = (el as HTMLElement).dataset.pm as 'cod' | 'online';
      document.querySelectorAll('.pm-option').forEach(opt => {
        const o = opt as HTMLElement;
        const active = o.dataset.pm === paymentMethod;
        o.style.borderColor = active ? 'var(--primary)' : 'var(--outline-variant)';
        o.style.background  = active ? 'var(--surface-container)' : 'transparent';
        const icon = o.querySelector('.pm-check') as HTMLElement;
        icon.textContent = active ? 'radio_button_checked' : 'radio_button_unchecked';
        icon.style.color = active ? 'var(--primary)' : 'var(--on-surface-variant)';
        icon.style.fontVariationSettings = active ? "'FILL' 1" : "'FILL' 0";
      });
      renderTotals();
    });
  });

  // ── Cart + totals ────────────────────────────────────────────────────
  function renderItems() {
    document.getElementById('order-items')!.innerHTML = cartItems.map(c => `
      <div style="display:grid; grid-template-columns:3rem 1fr; gap:0.75rem; align-items:center;">
        <div style="border-radius:0.4rem; overflow:hidden; aspect-ratio:3/4; background:var(--surface-container);">
          <img src="${c.image}" style="width:100%; height:100%; object-fit:cover;" />
        </div>
        <div>
          <div style="font-family:'Manrope',sans-serif; font-size:0.8rem; font-weight:600; color:var(--on-surface);">${c.name}</div>
          <div style="font-family:'Manrope',sans-serif; font-size:0.75rem; color:var(--on-surface-variant);">Qty: ${c.quantity||1} &nbsp;·&nbsp; ₹${((c.salePrice||0)*(c.quantity||1)).toFixed(2)}</div>
        </div>
      </div>
    `).join('');
  }

  function renderTotals() {
    const subtotal = cartItems.reduce((s, c) => s + (c.salePrice || 0) * (c.quantity || 1), 0);
    const r = rates;
    const freeShipThreshold = r?.freeShippingThreshold ?? 499;
    const shipping = subtotal <= freeShipThreshold ? (r?.shippingBelowThreshold ?? 49) : (r?.shippingAboveThreshold ?? 0);
    const tax = subtotal * (r?.taxPercentage ?? 0.05);
    const codCharge = paymentMethod === 'cod' ? (r?.codCharge ?? 0) : 0;
    const total = subtotal + shipping + tax + codCharge;

    document.getElementById('co-subtotal')!.textContent = `₹${subtotal.toFixed(2)}`;
    const shipEl = document.getElementById('co-shipping')!;
    shipEl.textContent = shipping === 0 ? 'FREE' : `₹${shipping.toFixed(2)}`;
    (shipEl as HTMLElement).style.color = shipping === 0 ? 'var(--tertiary)' : 'var(--on-surface-variant)';
    document.getElementById('co-tax')!.textContent = `₹${tax.toFixed(2)}`;

    const codRow = document.getElementById('co-codcharge-row')!;
    if (codCharge > 0) {
      codRow.style.display = 'flex';
      document.getElementById('co-codcharge')!.textContent = `₹${codCharge.toFixed(2)}`;
    } else {
      codRow.style.display = 'none';
    }

    document.getElementById('co-total')!.textContent = `₹${total.toFixed(2)}`;

    const bar  = document.getElementById('free-shipping-bar')!;
    const prog = document.getElementById('shipping-progress')!;
    const tip  = document.getElementById('shipping-tip')!;
    if (subtotal < freeShipThreshold) {
      const remaining = freeShipThreshold - subtotal;
      bar.style.display = 'block';
      tip.style.display = 'block';
      prog.style.width  = `${Math.min((subtotal / freeShipThreshold) * 100, 100)}%`;
      tip.textContent   = `Add ₹${remaining.toFixed(0)} more for FREE shipping!`;
    } else {
      bar.style.display = 'none';
      tip.style.display = 'none';
    }
  }

  function renderCartDependent() {
    const guard  = document.getElementById('empty-guard') as HTMLElement;
    const layout = document.getElementById('checkout-layout') as HTMLElement;
    if (cartItems.length === 0) {
      guard.style.display = 'block';
      layout.style.display = 'none';
      return;
    }
    guard.style.display = 'none';
    layout.style.display = '';
    renderItems();
    renderTotals();
  }

  function addressToBillingShipping(a: AddressDoc): BillingShipping {
    return {
      first_name: a.name,
      phone: a.phone,
      address_1: a.address,
      city: a.city,
      state: a.state,
      postcode: a.pincode,
      country: 'IN',
    };
  }

  // ── Place order ──────────────────────────────────────────────────────
  placeBtn.addEventListener('click', async () => {
    if (!uid || placingOrder) return;
    if (cartItems.length === 0) { showToast('Your bag is empty.', true); return; }
    const selected = addresses.find(a => a.id === selectedAddrId);
    if (!selected) { showToast('Please select or add a delivery address.', true); return; }

    placingOrder = true;
    placeBtn.disabled = true;
    placeBtn.style.opacity = '0.6';
    const originalLabel = placeBtn.innerHTML;
    placeBtn.innerHTML = '<span class="material-symbols-outlined" style="font-size:1.1rem;">hourglass_top</span> Placing Order…';

    const billingShipping = addressToBillingShipping(selected);

    try {
      const order = await createSecureOrder(paymentMethod, false);

      if (paymentMethod === 'cod' || order.finalPayable <= 0) {
        const result = await finalizeOrder({ billing: billingShipping, shipping: billingShipping, useWallet: false });
        window.location.href = `/order-success?id=${result.orderId}`;
        return;
      }

      // Online payment via Razorpay
      if (!order.razorpayOrderId || !order.razorpayKey) throw new Error('Could not start online payment');
      await loadRazorpayScript();

      openRazorpayCheckout({
        key: order.razorpayKey,
        amount: Math.round(order.finalPayable * 100),
        orderId: order.razorpayOrderId,
        name: 'Gladskin',
        description: 'Order Payment',
        contact: selected.phone,
        onSuccess: async (payload) => {
          try {
            placeBtn.innerHTML = '<span class="material-symbols-outlined" style="font-size:1.1rem;">hourglass_top</span> Confirming Payment…';
            const result = await finalizeOrder({
              razorpayOrderId: payload.razorpay_order_id,
              razorpayPaymentId: payload.razorpay_payment_id,
              razorpaySignature: payload.razorpay_signature,
              billing: billingShipping,
              shipping: billingShipping,
              useWallet: false,
            });
            window.location.href = `/order-success?id=${result.orderId}`;
          } catch {
            showToast('Payment received but order confirmation failed. Contact support.', true);
            placingOrder = false;
            placeBtn.disabled = false;
            placeBtn.style.opacity = '1';
            placeBtn.innerHTML = originalLabel;
          }
        },
        onDismiss: () => {
          placingOrder = false;
          placeBtn.disabled = false;
          placeBtn.style.opacity = '1';
          placeBtn.innerHTML = originalLabel;
        },
      });
    } catch (e: any) {
      showToast(e?.message || 'Checkout failed. Please try again.', true);
      placingOrder = false;
      placeBtn.disabled = false;
      placeBtn.style.opacity = '1';
      placeBtn.innerHTML = originalLabel;
    }
  });

  // ── Auth gate + data load ────────────────────────────────────────────
  subscribeToAuth(user => {
    if (unsubscribeCart) { unsubscribeCart(); unsubscribeCart = null; }
    if (!user) {
      window.location.href = '/login?next=/checkout';
      return;
    }
    uid = user.uid;

    unsubscribeCart = subscribeToCart(uid, items => {
      cartItems = items;
      renderCartDependent();
    });

    listAddresses(uid).then(list => { addresses = list; renderAddresses(); });
    getCartRates(paymentMethod).then(r => { rates = r; renderTotals(); }).catch(() => {});
  });
</script>
