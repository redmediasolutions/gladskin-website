---
import { fetchSubCategories } from '../lib/woocommerce';

interface Category {
  id: number;
  name: string;
  icon: string;
}

interface Props {
  selectedId?: number;
  activeSubCategoryId?: number;
}

const {
  selectedId = 49,
  activeSubCategoryId,
} = Astro.props;

const categories: Category[] = [
  {
    id: 49,
    name: 'All',
    icon: '/gladskin-all.webp',
  },
   {
    id: 45,
    name: 'Skin',
    icon:
      '/skin.jpeg',
  },
   {
    id: 36,
    name: 'Face',
    icon:
      'https://store.gladskin.in/wp-content/uploads/2026/06/Untitled-17-June-2026-at-10.11.41-2.png',
  },
  {
    id: 46,
    name: 'Hair',
    icon:
      'https://store.gladskin.in/wp-content/uploads/2026/06/Untitled-17-June-2026-at-10.11.41-3.png',
  },
  {
    id: 47,
    name: 'Hygiene',
    icon:
      'https://store.gladskin.in/wp-content/uploads/2026/06/Untitled-17-June-2026-at-10.11.41-1.png',
  },
 
];

const showSubCategories =
  selectedId !== 49;

const subCategories =
  showSubCategories
    ? await fetchSubCategories(
        selectedId,
      )
    : [];
---

<!-- PRIMARY -->

<div class="category-nav">
  {categories.map((cat) => (
    <a
      href={
        cat.id === 49
          ? '/collection'
          : `/category/${cat.id}`
      }
      class={`category-item ${
        selectedId === cat.id
          ? 'active'
          : ''
      }`}
    >
      <div class="category-icon">
        <img
          src={cat.icon}
          alt={cat.name}
          loading="lazy"
        />
      </div>

      <span class="category-name">
        {cat.name}
      </span>
    </a>
  ))}
</div>

<!-- SUB CATEGORIES -->

{
  showSubCategories &&
  subCategories.length > 0 && (
    <div class="sub-category-nav">
      {subCategories.map((sub) => (
        <a
          href={`/category/${sub.id}`}
          class={`sub-category-card ${
            activeSubCategoryId === sub.id
              ? 'active'
              : ''
          }`}
        >
          <span class="sub-category-title">
            {sub.name}
          </span>
        </a>
      ))}
    </div>
  )
}

<style>
  .category-nav {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    padding-bottom: 1rem;
    margin-bottom: 1rem;
    scrollbar-width: none;
  }

  .category-nav::-webkit-scrollbar {
    display: none;
  }

  .category-item {
    min-width: 90px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .category-icon {
    width: 84px;
    height: 84px;
    border-radius: 50%;
    overflow: hidden;
    background: white;

    display: flex;
    align-items: center;
    justify-content: center;

    border: 2px solid transparent;

    box-shadow:
      0 1px 3px rgba(0,0,0,.12),
      0 4px 12px rgba(0,0,0,.08);

    transition: all .2s ease;
  }

  .category-item:hover .category-icon {
    transform: translateY(-2px);

    box-shadow:
      0 4px 8px rgba(0,0,0,.12),
      0 8px 20px rgba(0,0,0,.12);
  }

  .category-item.active .category-icon {
    border-color: var(--primary);
  }

  .category-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .category-name {
    margin-top: 0.75rem;

    font-family: 'Manrope',
      sans-serif;

    font-size: 0.95rem;
    font-weight: 600;

    color: var(--on-surface);

    text-align: center;
  }

  .category-item.active .category-name {
    color: var(--primary);
    font-weight: 700;
  }
/* =========================
   SUB CATEGORY CARDS
========================= */

.sub-category-nav {
  display: flex;
  gap: 0.75rem;

  overflow-x: auto;

  padding-bottom: 0.5rem;
  margin-bottom: 2rem;

  scrollbar-width: none;
}

.sub-category-nav::-webkit-scrollbar {
  display: none;
}

.sub-category-card {
  flex-shrink: 0;

  min-width: 120px;

  padding: 0.9rem 1rem;

  border-radius: 18px;

  background: white;

  border: 1px solid
    var(--outline-variant);

  text-decoration: none;

  display: flex;
  align-items: center;
  justify-content: center;

  box-shadow:
    0 1px 3px rgba(0,0,0,.08),
    0 4px 10px rgba(0,0,0,.05);

  transition: all 0.2s ease;
}

.sub-category-card:hover {
  transform: translateY(-2px);

  box-shadow:
    0 6px 14px rgba(0,0,0,.10);
}

.sub-category-title {
  font-family: 'Manrope',
    sans-serif;

  font-size: 0.9rem;
  font-weight: 600;

  color: var(--on-surface);

  text-align: center;
  line-height: 1.3;
}

.sub-category-card.active {
  background: var(--primary);

  border-color: var(--primary);

  box-shadow:
    0 8px 18px
    rgba(143,42,141,.25);
}

.sub-category-card.active
  .sub-category-title {
  color: white;
}

@media (max-width: 768px) {
  .sub-category-card {
    min-width: 110px;

    padding: 0.8rem 0.9rem;
  }

  .sub-category-title {
    font-size: 0.85rem;
  }
}
</style>