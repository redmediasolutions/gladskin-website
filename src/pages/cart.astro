---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Your Bag | Gladskin">
  <Header />
  <main style="padding-top:3.25rem; min-height:100vh; background:var(--surface);">
    <div style="max-width:72rem; margin:0 auto; padding:1.5rem clamp(1.25rem,4vw,3rem) 3rem;">

      <h1 class="font-headline" style="font-size:clamp(1.75rem,3vw,2.5rem); color:var(--on-surface); margin:0 0 0.25rem;">Your Bag</h1>
      <p style="font-family:'Manrope',sans-serif; font-size:0.875rem; color:var(--on-surface-variant); margin:0 0 2rem;">
        <span id="cart-item-count">0</span> items
      </p>

      <!-- Empty state -->
      <div id="cart-empty" style="text-align:center; padding:5rem 0;">
        <span class="material-symbols-outlined" style="font-size:4rem; color:var(--outline-variant); display:block; margin-bottom:1.5rem;">shopping_bag</span>
        <p class="font-body" style="color:var(--on-surface-variant); font-size:1.125rem; margin:0 0 2rem;">Your bag is empty.</p>
        <a href="/collection" style="display:inline-block; padding:1rem 2.5rem; background:var(--primary); color:var(--on-primary); border-radius:9999px; font-family:'Manrope',sans-serif; font-weight:700; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; text-decoration:none;">
          Explore Collection
        </a>
      </div>

      <!-- Cart layout: items + summary -->
      <div id="cart-layout" style="display:none; gap:2rem;" class="cart-layout">

        <!-- Items list -->
        <div id="cart-items" style="display:flex; flex-direction:column; gap:1rem;"></div>

        <!-- Order summary -->
        <div style="background:var(--surface-container-low); border-radius:1rem; padding:1.5rem; height:fit-content; position:sticky; top:4rem;">

          <!-- Savings card — shown only when products have discounts -->
          <div id="savings-card" style="display:none; align-items:center; gap:0.75rem; background:linear-gradient(135deg,#FDF5F8,#F8E9F0); border:1px solid #E8C7D8; border-radius:0.875rem; padding:1rem 1.125rem; margin-bottom:1.25rem;">
            <div style="width:2.75rem; height:2.75rem; border-radius:50%; background:linear-gradient(135deg,#B34E6F,#6F0562); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span class="material-symbols-outlined" style="color:#fff; font-size:1.25rem; font-variation-settings:'FILL' 1;">auto_awesome</span>
            </div>
            <div style="flex:1; min-width:0;">
              <p style="font-family:'Manrope',sans-serif; font-size:0.7rem; color:#6b5c63; margin:0 0 0.1rem; font-weight:500; letter-spacing:0.02em;">Your Beauty Savings</p>
              <p id="savings-amount" style="font-family:'Manrope',sans-serif; font-size:1.5rem; font-weight:800; color:var(--primary); margin:0 0 0.1rem; line-height:1.1;">₹0</p>
              <p style="font-family:'Manrope',sans-serif; font-size:0.72rem; color:#B34E6F; font-weight:600; margin:0;">saved on this order ✨</p>
            </div>
            <div style="background:#fff; border-radius:9999px; padding:0.3rem 0.7rem; flex-shrink:0; box-shadow:0 1px 4px rgba(111,5,98,0.1);">
              <span style="font-family:'Manrope',sans-serif; font-size:0.58rem; font-weight:800; color:var(--primary); letter-spacing:0.12em; text-transform:uppercase;">YOU SAVE</span>
            </div>
          </div>

          <h2 style="font-family:'Manrope',sans-serif; font-size:0.8rem; font-weight:800; letter-spacing:0.15em; text-transform:uppercase; color:var(--on-surface); margin:0 0 1.25rem;">Order Summary</h2>
          <div style="display:flex; flex-direction:column; gap:0.75rem; margin-bottom:1.25rem; border-bottom:1px solid var(--outline-variant); padding-bottom:1.25rem;">
            <!-- MRP row — shown only when savings exist -->
            <div id="mrp-row" style="display:none; justify-content:space-between; font-family:'Manrope',sans-serif; font-size:0.875rem; color:#9a8a94;">
              <span>MRP</span><span id="mrp-total" style="text-decoration:line-through;">₹0</span>
            </div>
            <div style="display:flex; justify-content:space-between; font-family:'Manrope',sans-serif; font-size:0.875rem; color:var(--on-surface-variant);">
              <span>Sale Total</span><span id="subtotal">₹0</span>
            </div>
            <div style="display:flex; justify-content:space-between; font-family:'Manrope',sans-serif; font-size:0.875rem; color:var(--on-surface-variant);">
              <span>Shipping</span><span style="color:var(--tertiary); font-weight:700;">Free</span>
            </div>
          </div>
          <div style="display:flex; justify-content:space-between; font-family:'Noto Serif',serif; font-size:1.1rem; color:var(--on-surface); font-weight:400; margin-bottom:1.5rem;">
            <span>Total</span><span id="total">₹0</span>
          </div>
          <a href="/checkout" id="checkout-btn" style="display:flex; align-items:center; justify-content:center; gap:0.5rem; width:100%; padding:1rem; background:linear-gradient(135deg,var(--primary),var(--primary-container)); color:#fff; border:none; border-radius:9999px; font-family:'Manrope',sans-serif; font-weight:700; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; cursor:pointer; text-decoration:none;">
            <span class="material-symbols-outlined" style="font-size:1.1rem;">arrow_forward</span>
            Proceed to Checkout
          </a>
        </div>
      </div>

      <!-- Toast -->
      <div id="cart-toast" style="position:fixed; bottom:2rem; left:50%; transform:translateX(-50%) translateY(4rem); background:var(--on-surface); color:var(--surface); padding:0.75rem 1.5rem; border-radius:9999px; font-family:'Manrope',sans-serif; font-size:0.8rem; font-weight:600; opacity:0; transition:all 0.3s; z-index:100; white-space:nowrap;"></div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .cart-layout { display: none; flex-direction: column; }
  @media (min-width: 768px) {
    .cart-layout { grid-template-columns: 1fr 22rem !important; display: grid !important; }
  }
</style>

<script>
  import { subscribeToAuth } from '../lib/auth';
  import { subscribeToCart, subscribeToCartCount, changeCartQuantity, removeFromCart, type CartItemDoc } from '../lib/firestore-data';
  import type { Product } from '../types/index';

  const WISHLIST_KEY = 'gladskin_wishlist';
  function getWishlist() { try { return JSON.parse(localStorage.getItem(WISHLIST_KEY) || '[]'); } catch { return []; } }

  // Live catalog (real WooCommerce products + images), loaded via the
  // server-side /api/products proxy so credentials stay off the client.
  let catalog: Product[] = [];
  fetch('/api/products')
    .then(r => r.json())
    .then((data: Product[]) => {
      catalog = data;
      if (cartItems.length) renderCart(cartItems);
    })
    .catch(() => {});

  let uid: string | null = null;
  let unsubscribeCart: (() => void) | null = null;

  function showToast(msg: string) {
    const t = document.getElementById('cart-toast')!;
    t.textContent = msg;
    t.style.opacity = '1';
    t.style.transform = 'translateX(-50%) translateY(0)';
    setTimeout(() => { t.style.opacity='0'; t.style.transform='translateX(-50%) translateY(4rem)'; }, 2500);
  }

  function findLocalProduct(productId: number) {
    return catalog.find(p => p.id === String(productId));
  }

  function changeQty(productId: string, delta: number) {
    if (!uid) return;
    changeCartQuantity(uid, productId, delta);
  }

  function removeItem(productId: string) {
    if (!uid) return;
    removeFromCart(uid, productId);
    showToast('Item removed');
  }

  function moveToWishlist(item: CartItemDoc & { id: string }) {
    if (!uid) return;
    const local = findLocalProduct(item.productId);
    const wishlist = getWishlist();
    if (!wishlist.find((w: any) => w.id === item.id)) {
      wishlist.push({
        id: item.id,
        name: item.name,
        price: item.salePrice,
        originalPrice: item.mrp > item.salePrice ? item.mrp : undefined,
        image: item.image,
        imageAlt: item.name,
        slug: local?.slug || '',
        category: local?.category || '',
      });
      localStorage.setItem(WISHLIST_KEY, JSON.stringify(wishlist));
    }
    removeFromCart(uid, item.id);
    showToast('Moved to wishlist');
  }

  function renderCart(items: Array<CartItemDoc & { id: string }>) {
    const countEl    = document.getElementById('cart-item-count')!;
    const emptyEl    = document.getElementById('cart-empty')!;
    const layoutEl   = document.getElementById('cart-layout')!;
    const itemsEl    = document.getElementById('cart-items')!;
    const subtotalEl = document.getElementById('subtotal')!;
    const totalEl    = document.getElementById('total')!;

    const totalQty      = items.reduce((s, c) => s + (c.quantity || 1), 0);
    const totalAmt      = items.reduce((s, c) => s + (c.salePrice || 0) * (c.quantity || 1), 0);
    const totalMrp      = items.reduce((s, c) => s + (c.mrp || c.salePrice || 0) * (c.quantity || 1), 0);
    const totalSavings  = totalMrp - totalAmt;

    countEl.textContent = String(totalQty);

    if (items.length === 0) {
      emptyEl.style.display  = 'block';
      layoutEl.style.display = 'none';
      return;
    }

    emptyEl.style.display  = 'none';
    layoutEl.style.display = '';

    subtotalEl.textContent = `₹${totalAmt.toFixed(0)}`;
    totalEl.textContent    = `₹${totalAmt.toFixed(0)}`;

    // Savings card
    const savingsCard   = document.getElementById('savings-card')!;
    const savingsAmount = document.getElementById('savings-amount')!;
    const mrpRow        = document.getElementById('mrp-row')!;
    const mrpTotal      = document.getElementById('mrp-total')!;
    if (totalSavings > 0) {
      savingsCard.style.display = 'flex';
      savingsAmount.textContent = `₹${totalSavings.toFixed(0)}`;
      mrpRow.style.display      = 'flex';
      mrpTotal.textContent      = `₹${totalMrp.toFixed(0)}`;
    } else {
      savingsCard.style.display = 'none';
      mrpRow.style.display      = 'none';
    }

    itemsEl.innerHTML = items.map((item) => {
      const local = findLocalProduct(item.productId);
      const href  = local ? `/products/${local.slug}` : '#';
      const category = local?.category || '';
      return `
      <div style="display:grid; grid-template-columns:6rem 1fr; gap:1.25rem; align-items:center; background:var(--surface-container-lowest); border:1px solid var(--outline-variant); border-radius:1rem; padding:1.25rem;" class="cart-row">
        <a href="${href}" style="display:block; border-radius:0.5rem; overflow:hidden; aspect-ratio:3/4;">
          <img src="${item.image}" alt="${item.name}" style="width:100%; height:100%; object-fit:cover;" />
        </a>
        <div style="display:flex; flex-direction:column; gap:0.6rem;">
          <div>
            ${category ? `<span style="font-family:'Manrope',sans-serif; font-size:0.65rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:var(--on-surface-variant);">${category}</span>` : ''}
            <h3 style="font-family:'Noto Serif',serif; font-size:1.05rem; font-weight:400; color:var(--on-surface); margin:0.2rem 0 0;">${item.name}</h3>
            <div style="display:flex;align-items:baseline;gap:0.4rem;margin:0.2rem 0 0;">
              <span style="font-family:'Manrope',sans-serif; font-size:1.15rem; color:var(--primary); font-weight:700;">₹${((item.salePrice || 0) * (item.quantity || 1)).toFixed(0)}</span>
              ${item.mrp > item.salePrice ? `<span style="font-family:'Manrope',sans-serif;font-size:0.78rem;color:#9a8a94;text-decoration:line-through;">₹${(item.mrp * (item.quantity || 1)).toFixed(0)}</span><span style="font-family:'Manrope',sans-serif;font-size:0.65rem;font-weight:800;color:green;background:#e8f5e9;border:1px solid #a5d6a7;padding:0.1rem 0.45rem;border-radius:9999px;letter-spacing:0.05em;">${Math.round(((item.mrp - item.salePrice) / item.mrp) * 100)}% OFF</span>` : ''}
            </div>
            ${(item.quantity || 1) > 1 ? `<span style="font-family:'Manrope',sans-serif;font-size:0.7rem;color:var(--on-surface-variant);">${item.quantity} × ₹${(item.salePrice || 0).toFixed(0)}</span>` : ''}
            ${item.mrp > item.salePrice ? `<span style="font-family:'Manrope',sans-serif;font-size:0.72rem;font-weight:700;color:#B34E6F;">You save ₹${((item.mrp - item.salePrice) * (item.quantity || 1)).toFixed(0)}</span>` : ''}
          </div>
          <!-- Qty controls -->
          <div style="display:flex; align-items:center; gap:0.5rem;">
            <div style="display:flex; align-items:center; border:1px solid var(--outline-variant); border-radius:9999px; overflow:hidden;">
              <button onclick="window.__cartQty('${item.id}',-1)" style="padding:0.3rem 0.75rem; background:none; border:none; cursor:pointer; font-size:1rem; color:var(--on-surface);">−</button>
              <span style="padding:0.3rem 0.75rem; font-family:'Manrope',sans-serif; font-weight:600; min-width:2rem; text-align:center;">${item.quantity || 1}</span>
              <button onclick="window.__cartQty('${item.id}',1)" style="padding:0.3rem 0.75rem; background:none; border:none; cursor:pointer; font-size:1rem; color:var(--on-surface);">+</button>
            </div>
          </div>
          <!-- Actions -->
          <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
            <button onclick="window.__moveToWishlist('${item.id}')"
              style="padding:0.4rem 0.875rem; background:none; border:1px solid var(--outline-variant); border-radius:9999px; font-family:'Manrope',sans-serif; font-size:0.65rem; font-weight:600; color:var(--on-surface-variant); cursor:pointer; display:flex; align-items:center; gap:0.3rem;">
              <span class="material-symbols-outlined" style="font-size:0.9rem;">favorite_border</span> Save
            </button>
            <button onclick="window.__removeCart('${item.id}')"
              style="padding:0.4rem 0.875rem; background:none; border:1px solid var(--outline-variant); border-radius:9999px; font-family:'Manrope',sans-serif; font-size:0.65rem; font-weight:600; color:var(--error); cursor:pointer; display:flex; align-items:center; gap:0.3rem;">
              <span class="material-symbols-outlined" style="font-size:0.9rem;">delete</span> Remove
            </button>
          </div>
        </div>
      </div>
    `;
    }).join('');
  }

  let cartItems: Array<CartItemDoc & { id: string }> = [];

  (window as any).__removeCart = removeItem;
  (window as any).__cartQty    = changeQty;
  (window as any).__moveToWishlist = (id: string) => {
    const item = cartItems.find(i => i.id === id);
    if (item) moveToWishlist(item);
  };

  subscribeToAuth(user => {
    if (unsubscribeCart) { unsubscribeCart(); unsubscribeCart = null; }
    if (!user) {
      window.location.href = '/login?next=/cart';
      return;
    }
    uid = user.uid;
    unsubscribeCart = subscribeToCart(uid, items => {
      cartItems = items;
      renderCart(items);
    });
  });
</script>
