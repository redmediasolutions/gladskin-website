---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Profile | Gladskin" description="Your Gladskin member profile">
  <Header />

  <main style="padding-top:3.25rem; min-height:100vh; background:var(--surface); padding-bottom:5rem;">
    <div style="max-width:80rem; margin:0 auto; padding:0 clamp(1.25rem,4vw,3rem) 2rem;">

      <!-- ── Profile Hero ── -->
      <div class="profile-hero" style="display:flex; align-items:center; gap:2.5rem; padding:2rem 0 2.5rem;">
        <div style="width:6rem; height:6rem; border-radius:9999px; overflow:hidden; border:3px solid var(--primary); flex-shrink:0; background:var(--surface-container); display:flex; align-items:center; justify-content:center;">
          <span class="material-symbols-outlined" style="font-size:3rem; color:var(--primary);">person</span>
        </div>
        <div>
          <h1 id="profile-name" style="font-family:'Noto Serif',serif; font-size:clamp(1.75rem,4vw,2.75rem); font-weight:400; color:var(--on-surface); margin:0 0 0.4rem; line-height:1.1;">—</h1>
          <p id="profile-phone" style="font-family:'Manrope',sans-serif; font-size:0.85rem; color:var(--on-surface-variant); margin:0 0 0.75rem;"></p>
          <div style="display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap;">
            <div style="display:inline-flex; align-items:center; gap:0.5rem; background:var(--surface-container); border-radius:9999px; padding:0.45rem 1rem;">
              <span class="material-symbols-outlined" style="font-size:1rem; color:var(--secondary);">currency_exchange</span>
              <span style="font-family:'Manrope',sans-serif; font-size:0.7rem; font-weight:700; color:var(--on-surface-variant); text-transform:uppercase; letter-spacing:0.12em;">Points</span>
              <span id="profile-points" style="font-family:'Manrope',sans-serif; font-size:0.875rem; font-weight:800; color:var(--on-surface);">0</span>
            </div>
            <button id="sign-out-btn" style="display:inline-flex; align-items:center; gap:0.4rem; padding:0.45rem 1.1rem; background:none; border:1px solid var(--outline-variant); border-radius:9999px; font-family:'Manrope',sans-serif; font-size:0.7rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--on-surface-variant); cursor:pointer;">
              <span class="material-symbols-outlined" style="font-size:0.95rem;">logout</span> Sign Out
            </button>
          </div>
        </div>
      </div>

      <!-- ── Row 1: 3 cards ── -->
      <div class="cards-row-1" style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:1rem; margin-bottom:1rem;">

        <!-- Order History -->
        <a href="/orders" style="text-decoration:none; display:flex; flex-direction:column; justify-content:space-between; background:var(--surface-container-lowest); border:1px solid var(--outline-variant); border-radius:1.25rem; padding:1.75rem; min-height:12rem; transition:box-shadow 0.2s,border-color 0.2s;" onmouseover="this.style.boxShadow='0 4px 20px rgba(111,5,98,0.08)';this.style.borderColor='var(--primary)'" onmouseout="this.style.boxShadow='none';this.style.borderColor='var(--outline-variant)'">
          <div style="width:2.75rem; height:2.75rem; background:var(--surface-container); border-radius:0.875rem; display:flex; align-items:center; justify-content:center;">
            <span class="material-symbols-outlined" style="font-size:1.375rem; color:var(--primary);">receipt_long</span>
          </div>
          <div>
            <div style="font-family:'Manrope',sans-serif; font-size:1.1rem; font-weight:700; color:var(--on-surface); margin-bottom:0.25rem;">Order History</div>
            <div id="orders-count-label" style="font-family:'Manrope',sans-serif; font-size:0.78rem; color:var(--on-surface-variant);">0 Orders</div>
          </div>
          <span class="material-symbols-outlined" style="font-size:1.25rem; color:var(--outline); align-self:flex-end;">chevron_right</span>
        </a>

        <!-- Saved Items -->
        <a href="/saved" style="text-decoration:none; display:flex; flex-direction:column; justify-content:space-between; background:var(--surface-container-lowest); border:1px solid var(--outline-variant); border-radius:1.25rem; padding:1.75rem; min-height:12rem; transition:box-shadow 0.2s,border-color 0.2s;" onmouseover="this.style.boxShadow='0 4px 20px rgba(111,5,98,0.08)';this.style.borderColor='var(--primary)'" onmouseout="this.style.boxShadow='none';this.style.borderColor='var(--outline-variant)'">
          <div style="width:2.75rem; height:2.75rem; background:var(--surface-container); border-radius:0.875rem; display:flex; align-items:center; justify-content:center;">
            <span class="material-symbols-outlined" style="font-size:1.375rem; color:var(--secondary);">favorite</span>
          </div>
          <div>
            <div style="font-family:'Manrope',sans-serif; font-size:1.1rem; font-weight:700; color:var(--on-surface); margin-bottom:0.25rem;">Saved Items</div>
            <div id="wishlist-count-label" style="font-family:'Manrope',sans-serif; font-size:0.78rem; color:var(--on-surface-variant);">0 Items</div>
          </div>
          <span class="material-symbols-outlined" style="font-size:1.25rem; color:var(--outline); align-self:flex-end;">chevron_right</span>
        </a>

        <!-- Loyalty Points — featured dark card -->
        <div style="display:flex; flex-direction:column; justify-content:space-between; background:var(--primary); border-radius:1.25rem; padding:1.75rem; min-height:12rem; position:relative; overflow:hidden;">
          <div style="position:absolute; right:-1rem; bottom:-1rem; opacity:0.10;">
            <span class="material-symbols-outlined" style="font-size:8rem; color:#fff;">wallet</span>
          </div>
          <div style="width:2.75rem; height:2.75rem; background:rgba(255,255,255,0.15); border-radius:0.875rem; display:flex; align-items:center; justify-content:center;">
            <span class="material-symbols-outlined" style="font-size:1.375rem; color:#fff;">stars</span>
          </div>
          <div>
            <div style="font-family:'Manrope',sans-serif; font-size:1.1rem; font-weight:700; color:#fff; margin-bottom:0.6rem;">Loyalty Points</div>
            <!-- Points row -->
            <div style="display:flex; align-items:center; justify-content:space-between; background:rgba(255,255,255,0.12); border-radius:0.625rem; padding:0.45rem 0.75rem; margin-bottom:0.4rem;">
              <span style="font-family:'Manrope',sans-serif; font-size:0.68rem; font-weight:600; color:rgba(255,255,255,0.8); text-transform:uppercase; letter-spacing:0.1em;">Reward Points</span>
              <span id="loyalty-points-val" style="font-family:'Manrope',sans-serif; font-size:0.88rem; font-weight:800; color:#fff;">0</span>
            </div>
            <!-- Wallet row -->
            <div style="display:flex; align-items:center; justify-content:space-between; background:rgba(255,255,255,0.12); border-radius:0.625rem; padding:0.45rem 0.75rem;">
              <span style="font-family:'Manrope',sans-serif; font-size:0.68rem; font-weight:600; color:rgba(255,255,255,0.8); text-transform:uppercase; letter-spacing:0.1em;">Wallet Balance</span>
              <span id="loyalty-wallet-val" style="font-family:'Manrope',sans-serif; font-size:0.88rem; font-weight:800; color:#fff;">₹0</span>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Row 2: 2 cards ── -->
      <div class="cards-row-2" style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:2rem;">

        <!-- Addresses -->
        <a href="/addresses" style="text-decoration:none; display:flex; flex-direction:column; justify-content:space-between; background:var(--surface-container-lowest); border:1px solid var(--outline-variant); border-radius:1.25rem; padding:1.75rem; min-height:9rem; transition:box-shadow 0.2s,border-color 0.2s;" onmouseover="this.style.boxShadow='0 4px 20px rgba(111,5,98,0.08)';this.style.borderColor='var(--primary)'" onmouseout="this.style.boxShadow='none';this.style.borderColor='var(--outline-variant)'">
          <div style="width:2.75rem; height:2.75rem; background:var(--surface-container); border-radius:0.875rem; display:flex; align-items:center; justify-content:center;">
            <span class="material-symbols-outlined" style="font-size:1.375rem; color:var(--tertiary);">location_on</span>
          </div>
          <div>
            <div style="font-family:'Manrope',sans-serif; font-size:1.1rem; font-weight:700; color:var(--on-surface); margin-bottom:0.25rem;">My Addresses</div>
            <div id="addresses-count-label" style="font-family:'Manrope',sans-serif; font-size:0.78rem; color:var(--on-surface-variant);">0 Saved</div>
          </div>
        </a>

        <!-- Browse Collection -->
        <a href="/collection" style="text-decoration:none; display:flex; flex-direction:column; justify-content:space-between; background:var(--surface-container-lowest); border:1px solid var(--outline-variant); border-radius:1.25rem; padding:1.75rem; min-height:9rem; transition:box-shadow 0.2s,border-color 0.2s;" onmouseover="this.style.boxShadow='0 4px 20px rgba(111,5,98,0.08)';this.style.borderColor='var(--primary)'" onmouseout="this.style.boxShadow='none';this.style.borderColor='var(--outline-variant)'">
          <div style="width:2.75rem; height:2.75rem; background:var(--surface-container); border-radius:0.875rem; display:flex; align-items:center; justify-content:center;">
            <span class="material-symbols-outlined" style="font-size:1.375rem; color:var(--primary);">spa</span>
          </div>
          <div>
            <div style="font-family:'Manrope',sans-serif; font-size:1.1rem; font-weight:700; color:var(--on-surface); margin-bottom:0.25rem;">Browse Collection</div>
            <div style="font-family:'Manrope',sans-serif; font-size:0.78rem; color:var(--on-surface-variant);">Explore all products</div>
          </div>
        </a>
      </div>

    </div>
  </main>

  <!-- Bottom nav — mobile only -->
  <nav class="mobile-bottom-nav" style="position:fixed; bottom:0; left:0; right:0; background:var(--surface); border-top:1px solid var(--outline-variant); display:flex; justify-content:space-around; align-items:center; padding:0.75rem 0 calc(0.75rem + env(safe-area-inset-bottom)); z-index:50;">
    <a href="/" style="display:flex; flex-direction:column; align-items:center; gap:0.2rem; text-decoration:none; color:var(--on-surface-variant);">
      <span class="material-symbols-outlined" style="font-size:1.5rem;">home</span>
      <span style="font-family:'Manrope',sans-serif; font-size:0.6rem; font-weight:600; letter-spacing:0.08em; text-transform:uppercase;">Shop</span>
    </a>
    <a href="/collection" style="display:flex; flex-direction:column; align-items:center; gap:0.2rem; text-decoration:none; color:var(--on-surface-variant);">
      <span class="material-symbols-outlined" style="font-size:1.5rem;">grid_view</span>
      <span style="font-family:'Manrope',sans-serif; font-size:0.6rem; font-weight:600; letter-spacing:0.08em; text-transform:uppercase;">Discover</span>
    </a>
    <a href="/saved" style="display:flex; flex-direction:column; align-items:center; gap:0.2rem; text-decoration:none; color:var(--on-surface-variant);">
      <span class="material-symbols-outlined" style="font-size:1.5rem;">favorite</span>
      <span style="font-family:'Manrope',sans-serif; font-size:0.6rem; font-weight:600; letter-spacing:0.08em; text-transform:uppercase;">Wishlist</span>
    </a>
    <a href="/profile" style="display:flex; flex-direction:column; align-items:center; gap:0.2rem; text-decoration:none; color:var(--primary);">
      <span class="material-symbols-outlined" style="font-size:1.5rem; font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24;">person</span>
      <span style="font-family:'Manrope',sans-serif; font-size:0.6rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--primary);">Profile</span>
    </a>
  </nav>

  <Footer />
</BaseLayout>

<style>
  .mobile-bottom-nav { display: none; }

  @media (max-width: 767px) {
    .mobile-bottom-nav { display: flex; }
    .profile-hero { flex-direction: column; align-items: center; text-align: center; }
    .cards-row-1  { grid-template-columns: 1fr !important; }
    .cards-row-2  { grid-template-columns: 1fr !important; }
  }
  @media (max-width: 1023px) and (min-width: 768px) {
    .cards-row-1 { grid-template-columns: 1fr 1fr !important; }
  }
</style>

<script>
  import { subscribeToAuth, logout } from '../lib/auth';
  import { getUserProfile, listAddresses, listOrders } from '../lib/firestore-data';

  function getWishlistCount() {
    try { return JSON.parse(localStorage.getItem('gladskin_wishlist') || '[]').length; } catch { return 0; }
  }

  document.getElementById('sign-out-btn')!.addEventListener('click', async () => {
    await logout();
    window.location.href = '/';
  });

  subscribeToAuth(user => {
    if (!user) {
      window.location.href = '/login?next=/profile';
      return;
    }

    const wCount = getWishlistCount();
    const w = document.getElementById('wishlist-count-label');
    if (w) w.textContent = `${wCount} Item${wCount !== 1 ? 's' : ''}`;

    getUserProfile(user.uid).then(profile => {
      const nameEl      = document.getElementById('profile-name')!;
      const phoneEl     = document.getElementById('profile-phone')!;
      const pointsEl    = document.getElementById('profile-points')!;
      const loyaltyPts  = document.getElementById('loyalty-points-val')!;
      const loyaltyWal  = document.getElementById('loyalty-wallet-val')!;

      const name = profile?.display_name?.trim() || profile?.phone_number || 'Member';
      nameEl.textContent  = name;
      phoneEl.textContent = profile?.phone_number || '';

      const points  = profile?.rewardPoints  ?? 0;
      const wallet  = profile?.walletBalance ?? 0;

      pointsEl.textContent   = points.toLocaleString('en-IN');
      loyaltyPts.textContent = points.toLocaleString('en-IN');
      loyaltyWal.textContent = `₹${wallet.toLocaleString('en-IN')}`;
    });

    listOrders(user.uid).then(orders => {
      const o = document.getElementById('orders-count-label');
      if (o) o.textContent = `${orders.length} Order${orders.length !== 1 ? 's' : ''}`;
    }).catch(() => {});

    listAddresses(user.uid).then(addrs => {
      const a = document.getElementById('addresses-count-label');
      if (a) a.textContent = `${addrs.length} Location${addrs.length !== 1 ? 's' : ''} saved`;
    }).catch(() => {});
  });
</script>
